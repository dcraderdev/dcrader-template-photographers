{
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(webp|avif|jpg|jpeg|png|svg|ico|woff2|woff)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/", "has": [{ "type": "host", "value": "emmahayesphoto.dcrader.dev" }], "destination": "/v1-cinematic-quiet", "permanent": false },
    { "source": "/", "has": [{ "type": "host", "value": "dariavolkov.dcrader.dev" }], "destination": "/v2-bold-editorial", "permanent": false },
    { "source": "/", "has": [{ "type": "host", "value": "rubyandwilder.dcrader.dev" }], "destination": "/v3-bohemian-warm", "permanent": false },
    { "source": "/", "has": [{ "type": "host", "value": "lenaschultz.dcrader.dev" }], "destination": "/v4-modern-minimal", "permanent": false },
    { "source": "/", "has": [{ "type": "host", "value": "popandbloomphoto.dcrader.dev" }], "destination": "/v5-vibrant-joyful", "permanent": false }
  ],
  "rewrites": [
    { "source": "/(.+)", "has": [{ "type": "host", "value": "emmahayesphoto.dcrader.dev" }], "destination": "/v1-cinematic-quiet/$1" },
    { "source": "/(.+)", "has": [{ "type": "host", "value": "dariavolkov.dcrader.dev" }], "destination": "/v2-bold-editorial/$1" },
    { "source": "/(.+)", "has": [{ "type": "host", "value": "rubyandwilder.dcrader.dev" }], "destination": "/v3-bohemian-warm/$1" },
    { "source": "/(.+)", "has": [{ "type": "host", "value": "lenaschultz.dcrader.dev" }], "destination": "/v4-modern-minimal/$1" },
    { "source": "/(.+)", "has": [{ "type": "host", "value": "popandbloomphoto.dcrader.dev" }], "destination": "/v5-vibrant-joyful/$1" }
  ]
}
