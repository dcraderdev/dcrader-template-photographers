---
import BaseLayout from '../layouts/BaseLayout.astro';
import SharedNav from '../components/shared/SharedNav.astro';
import TestimonialHero from '../components/photographers/TestimonialHero.astro';
import Galleries from '../components/v4/Galleries.astro';
import About from '../components/v4/About.astro';
import ProcessFlowchart from '../components/v4/ProcessFlowchart.astro';
import Services from '../components/v4/Services.astro';
import SharedInvestmentGuide from '../components/shared/SharedInvestmentGuide.astro';
import Testimonials from '../components/v4/Testimonials.astro';
import SharedInquiryForm from '../components/shared/SharedInquiryForm.astro';
import Footer from '../components/v4/Footer.astro';

import { photographer } from '../data/v4/photographer';
import { galleries } from '../data/v4/galleries';
import { packages, investmentGuide } from '../data/v4/packages';
import { testimonials } from '../data/v4/testimonials';

const galleriesJson = JSON.stringify(galleries);

const instagramPosts = [
  { src: '/images/1519225421980-715cb0215aed-400.webp', alt: 'Couple at Villa d\'Este, Lake Como' },
  { src: '/images/1606800052052-a08af7148866-400.webp', alt: 'Newlyweds in the geometric gardens of Château de Chambord' },
  { src: '/images/1511285560929-80b456fea0bc-400.webp', alt: 'Couple in a Scandinavian design museum' },
  { src: '/images/1591604466107-ec97de577aff-400.webp', alt: 'Couple in industrial architectural space in Berlin' },
  { src: '/images/1537633552985-df8429e8048b-400.webp', alt: 'Minimalist ceremony at a Tuscan villa' },
  { src: '/images/1469371670807-013ccf25f16a-400.webp', alt: 'Couple on a Mallorca clifftop at golden hour' },
];
---
<BaseLayout
  title={`${photographer.business} | ${photographer.subtagline}`}
  description={`${photographer.tagline} ${photographer.subtagline}.`}
  ogImage={photographer.heroImage}
  themeClass="theme-v4"
  heroPreload={photographer.heroImage}
>
  <SharedNav name={photographer.name} variant="v4" />
  <main id="main-content">
    <!-- V4 — Testimonial hero: client letters lead. Praise → references → work → method. -->
    <TestimonialHero
      name={photographer.name}
      subtagline={photographer.subtagline}
      tagline={photographer.tagline}
      heroImage={photographer.heroImage}
      heroImageAlt={photographer.heroImageAlt}
      testimonials={testimonials}
    />
    <Testimonials testimonials={testimonials} />
    <About
      name={photographer.name}
      portraitImage={photographer.portraitImage}
      portraitAlt={photographer.portraitAlt}
      aboutParagraph1={photographer.aboutParagraph1}
      aboutParagraph2={photographer.aboutParagraph2}
      philosophyQuote={photographer.philosophyQuote}
      philosophyAuthor={photographer.philosophyAuthor}
    />
    <Galleries galleries={galleries} galleriesJson={galleriesJson} />
    <ProcessFlowchart />
    <Services packages={packages} />
    <SharedInvestmentGuide headline={investmentGuide.headline} subline={investmentGuide.subline} ctaLabel={investmentGuide.ctaLabel} />
    <SharedInquiryForm
      name={photographer.name} email={photographer.email}
      location={photographer.location} instagramUrl={photographer.instagramUrl}
      instagram={photographer.instagram}
      heading="Begin an enquiry."
      subheading="The studio accepts five weddings each year. Enquiries are read personally and answered within 48 hours. Please include the date and venue if known."
      submitLabel="Send enquiry"
    />
  </main>
  <Footer
    name={photographer.name} business={photographer.business}
    subtagline={photographer.subtagline} instagram={photographer.instagram}
    instagramUrl={photographer.instagramUrl} instagramPosts={instagramPosts}
  />
</BaseLayout>
