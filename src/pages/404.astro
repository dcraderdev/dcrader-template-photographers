---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Page Not Found · Photographer Templates"
  description="This frame didn't develop. Head back to the gallery of photographer landing page templates."
  themeClass="theme-v1"
>
  <div
    style="background:#0f0e0d;min-height:100vh;font-family:'Manrope',system-ui,sans-serif;color:#f5f0eb;display:flex;align-items:center;justify-content:center"
  >
    <main
      class="max-w-screen-md mx-auto px-6 lg:px-16 py-24 text-center"
      id="main-content"
    >
      <p
        class="text-[10px] uppercase tracking-[0.4em] mb-8"
        style="color:#c9a99a"
      >
        dcrader.dev — Template Series
      </p>

      <h1
        style="font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(6rem,18vw,12rem);color:#c9a99a;line-height:0.9;letter-spacing:-0.03em;margin-bottom:1rem"
      >
        404
      </h1>

      <div class="flex items-center justify-center gap-6 mb-8">
        <div
          class="w-12 h-px"
          style="background:#c9a99a"
          aria-hidden="true"
        ></div>
        <p
          class="text-xs uppercase tracking-[0.3em]"
          style="color:rgba(245,240,235,0.55)"
        >
          Page not found
        </p>
        <div
          class="w-12 h-px"
          style="background:#c9a99a"
          aria-hidden="true"
        ></div>
      </div>

      <h2
        style="font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(1.75rem,4vw,2.75rem);color:#f5f0eb;line-height:1.1;letter-spacing:-0.01em;margin-bottom:1.25rem"
      >
        This frame didn't develop.
      </h2>

      <p
        class="text-sm font-light mx-auto mb-12"
        style="color:rgba(245,240,235,0.55);max-width:48ch;line-height:1.7"
      >
        The page you were looking for slipped out of focus. Head back to the
        gallery and pick a template that's ready for its close-up.
      </p>

      <a
        href="/"
        class="inline-block text-xs uppercase tracking-[0.3em] px-8 py-4 transition-colors duration-300"
        style="border:1px solid #c9a99a;color:#f5f0eb;background:transparent"
        onmouseover="this.style.background='#c9a99a';this.style.color='#0f0e0d'"
        onmouseout="this.style.background='transparent';this.style.color='#f5f0eb'"
      >
        ← Back to home
      </a>
    </main>
  </div>
</BaseLayout>
