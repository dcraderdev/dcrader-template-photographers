---
import BaseLayout from '../layouts/BaseLayout.astro';
import SharedNav from '../components/shared/SharedNav.astro';
import BookingHero from '../components/photographers/BookingHero.astro';
import Galleries from '../components/v5/Galleries.astro';
import About from '../components/v5/About.astro';
import Services from '../components/v5/Services.astro';
import SharedInvestmentGuide from '../components/shared/SharedInvestmentGuide.astro';
import Testimonials from '../components/v5/Testimonials.astro';
import Process from '../components/v5/Process.astro';
import SharedInquiryForm from '../components/shared/SharedInquiryForm.astro';
import Footer from '../components/v5/Footer.astro';

import { photographer } from '../data/v5/photographer';
import { galleries } from '../data/v5/galleries';
import { packages, investmentGuide } from '../data/v5/packages';
import { testimonials } from '../data/v5/testimonials';

const galleriesJson = JSON.stringify(galleries);

const instagramPosts = [
  { src: '/images/1583939003579-730e3918a45a-400.webp', alt: 'Couple kissing as guests shower them with flower petals at an outdoor Austin celebration' },
  { src: '/images/1511285560929-80b456fea0bc-400.webp', alt: 'Colorful balloon release at a joyful outdoor Texas wedding celebration' },
  { src: '/images/1519741497674-611481863552-400.webp', alt: 'Golden hour couple portraits at a warm Austin outdoor wedding venue' },
  { src: '/images/1525772764200-be829a350797-400.webp', alt: 'Festive reception tables styled with vibrant florals and warm candlelight' },
  { src: '/images/1469371670807-013ccf25f16a-400.webp', alt: 'Guests standing and cheering as the newlyweds walk down the aisle' },
  { src: '/images/1537633552985-df8429e8048b-400.webp', alt: 'Dramatic couple portrait at sunset, veil sweeping in the breeze' },
];
---
<BaseLayout
  title={`${photographer.business} | ${photographer.subtagline}`}
  description={`${photographer.tagline} ${photographer.subtagline}.`}
  ogImage={photographer.heroImage}
  themeClass="theme-v5"
  heroPreload={photographer.heroImage}
>
  <SharedNav name={photographer.name} variant="v5" />
  <main id="main-content">
    <!-- V5 — Booking hero: pick a date + session type up top, then sell the experience. -->
    <BookingHero
      name={photographer.name}
      subtagline={photographer.subtagline}
      tagline={photographer.tagline}
      heroImage={photographer.heroImage}
      heroImageAlt={photographer.heroImageAlt}
    />
    <Process steps={photographer.process} />
    <Services packages={packages} />
    <Galleries galleries={galleries} galleriesJson={galleriesJson} />
    <Testimonials testimonials={testimonials} />
    <About
      name={photographer.name}
      portraitImage={photographer.portraitImage}
      portraitAlt={photographer.portraitAlt}
      aboutParagraph1={photographer.aboutParagraph1}
      aboutParagraph2={photographer.aboutParagraph2}
      philosophyQuote={photographer.philosophyQuote}
      philosophyAuthor={photographer.philosophyAuthor}
    />
    <SharedInvestmentGuide headline={investmentGuide.headline} subline={investmentGuide.subline} ctaLabel={investmentGuide.ctaLabel} />
    <SharedInquiryForm
      name={photographer.name} email={photographer.email}
      location={photographer.location} instagramUrl={photographer.instagramUrl}
      instagram={photographer.instagram}
      heading="Slide into our inbox 🎉"
      subheading="Tell us about your party! The more chaotic the details, the better. We answer every inquiry (and most DMs) within 48 hours — usually with too many emoji."
      submitLabel="Send it! ✨"
    />
  </main>
  <Footer
    name={photographer.name} business={photographer.business}
    subtagline={photographer.subtagline} instagram={photographer.instagram}
    instagramUrl={photographer.instagramUrl} instagramPosts={instagramPosts}
  />
</BaseLayout>
