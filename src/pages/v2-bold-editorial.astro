---
import BaseLayout from '../layouts/BaseLayout.astro';
import SharedNav from '../components/shared/SharedNav.astro';
import Hero from '../components/v2/Hero.astro';
import Galleries from '../components/v2/Galleries.astro';
import About from '../components/v2/About.astro';
import Services from '../components/v2/Services.astro';
import SharedInvestmentGuide from '../components/shared/SharedInvestmentGuide.astro';
import SharedTestimonials from '../components/shared/SharedTestimonials.astro';
import SharedProcess from '../components/shared/SharedProcess.astro';
import SharedInquiryForm from '../components/shared/SharedInquiryForm.astro';
import SharedFooter from '../components/shared/SharedFooter.astro';

import { photographer } from '../data/v2/photographer';
import { galleries } from '../data/v2/galleries';
import { packages, investmentGuide } from '../data/v2/packages';
import { testimonials } from '../data/v2/testimonials';

const galleriesJson = JSON.stringify(galleries);

const instagramPosts = [
  { src: 'https://images.unsplash.com/photo-1525772764200-be829a350797?w=400&q=80&fm=webp&fit=crop', alt: 'Candlelit reception at a grand New York City wedding venue' },
  { src: 'https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=400&q=80&fm=webp&fit=crop', alt: 'Couple in sharp editorial wedding attire at an industrial loft venue' },
  { src: 'https://images.unsplash.com/photo-1606800052052-a08af7148866?w=400&q=80&fm=webp&fit=crop', alt: 'Newlyweds photographed at night in an iconic European setting' },
  { src: 'https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=400&q=80&fm=webp&fit=crop', alt: 'Couple in sleek wedding attire photographed in the city at twilight' },
  { src: 'https://images.unsplash.com/photo-1537633552985-df8429e8048b?w=400&q=80&fm=webp&fit=crop', alt: 'Bold editorial portrait session in a dramatic outdoor setting' },
  { src: 'https://images.unsplash.com/photo-1583939003579-730e3918a45a?w=400&q=80&fm=webp&fit=crop', alt: 'Joyful moment as the couple is celebrated by their guests' },
];
---
<BaseLayout
  title={`${photographer.business} | ${photographer.subtagline}`}
  description={`${photographer.tagline} ${photographer.subtagline}.`}
  ogImage={photographer.heroImage}
  themeClass="theme-v2"
  heroPreload={photographer.heroImage}
>
  <SharedNav name={photographer.name} variant="v2" />
  <main id="main-content">
    <Hero
      name={photographer.name}
      subtagline={photographer.subtagline}
      tagline={photographer.tagline}
      heroImage={photographer.heroImage}
      heroImageAlt={photographer.heroImageAlt}
    />
    <Galleries galleries={galleries} galleriesJson={galleriesJson} />
    <About
      name={photographer.name}
      portraitImage={photographer.portraitImage}
      portraitAlt={photographer.portraitAlt}
      aboutParagraph1={photographer.aboutParagraph1}
      aboutParagraph2={photographer.aboutParagraph2}
      philosophyQuote={photographer.philosophyQuote}
      philosophyAuthor={photographer.philosophyAuthor}
    />
    <Services packages={packages} />
    <SharedInvestmentGuide headline={investmentGuide.headline} subline={investmentGuide.subline} ctaLabel={investmentGuide.ctaLabel} />
    <SharedTestimonials testimonials={testimonials} label="Press & Praise" heading="What clients say" />
    <SharedProcess steps={photographer.process} label="The Process" heading="How We Work" />
    <SharedInquiryForm
      name={photographer.name} email={photographer.email}
      location={photographer.location} instagramUrl={photographer.instagramUrl}
      instagram={photographer.instagram}
      heading="Book a session"
      subheading="Every inquiry is reviewed personally. Tell me about your event and I'll respond within 24 hours."
      submitLabel="Submit Inquiry"
    />
  </main>
  <SharedFooter
    name={photographer.name} business={photographer.business}
    subtagline={photographer.subtagline} instagram={photographer.instagram}
    instagramUrl={photographer.instagramUrl} instagramPosts={instagramPosts}
  />
</BaseLayout>
