---
import BaseLayout from '../layouts/BaseLayout.astro';
import SharedNav from '../components/shared/SharedNav.astro';
import CinematicHero from '../components/photographers/CinematicHero.astro';
import Galleries from '../components/Galleries.astro';
import About from '../components/About.astro';
import SignatureFrame from '../components/v1/SignatureFrame.astro';
import Services from '../components/Services.astro';
import SharedInvestmentGuide from '../components/shared/SharedInvestmentGuide.astro';
import Testimonials from '../components/v1/Testimonials.astro';
import Process from '../components/v1/Process.astro';
import SharedInquiryForm from '../components/shared/SharedInquiryForm.astro';
import Footer from '../components/v1/Footer.astro';

import { photographer } from '../data/v1/photographer';
import { galleries } from '../data/v1/galleries';
import { packages, investmentGuide } from '../data/v1/packages';
import { testimonials } from '../data/v1/testimonials';

const instagramPosts = [
  { src: '/images/1519741497674-611481863552-400.webp', alt: 'Bride and groom walking through a vineyard at golden hour' },
  { src: '/images/1583939003579-730e3918a45a-400.webp', alt: 'Couple walking hand in hand in a sunlit meadow on their wedding day' },
  { src: '/images/1591604466107-ec97de577aff-400.webp', alt: 'Newlyweds embracing on a cliff overlooking the ocean' },
  { src: '/images/1537633552985-df8429e8048b-400.webp', alt: 'Bride laughing with bridesmaids on a sunny terrace' },
  { src: '/images/1606800052052-a08af7148866-400.webp', alt: 'Bride and groom sharing a first look in a vineyard' },
  { src: '/images/1583939003579-730e3918a45a-400.webp', alt: 'Bride in lace gown standing in a cottage garden' },
];
---
<BaseLayout
  title={`${photographer.business} | ${photographer.subtagline}`}
  description={`${photographer.tagline} ${photographer.subtagline}.`}
  ogImage={photographer.heroImage}
  themeClass="theme-v1"
  heroPreload={photographer.heroImage}
>
  <SharedNav name={photographer.name} variant="v1" extraLink={{ href: '/v1-cinematic-quiet/experience', label: 'The Day' }} />
  <main id="main-content">
    <!-- V1 — Cinematic quiet: a single hero frame, then breath, then story. -->
    <CinematicHero
      name={photographer.name}
      subtagline={photographer.subtagline}
      tagline={photographer.tagline}
      heroImage={photographer.heroImage}
      heroImageAlt={photographer.heroImageAlt}
    />
    <SignatureFrame />
    <About />
    <Galleries />
    <Process steps={photographer.process} />
    <Testimonials testimonials={testimonials} />
    <Services />
    <SharedInvestmentGuide headline={investmentGuide.headline} subline={investmentGuide.subline} ctaLabel={investmentGuide.ctaLabel} />
    <SharedInquiryForm
      name={photographer.name} email={photographer.email}
      location={photographer.location} instagramUrl={photographer.instagramUrl}
      instagram={photographer.instagram}
      heading="Write to me"
      subheading="Tell me about your day — even just a few sentences. I read every message in the morning, with coffee, before anything else."
      submitLabel="Send the letter"
    />
  </main>
  <Footer
    name={photographer.name} business={photographer.business}
    subtagline={photographer.subtagline} instagram={photographer.instagram}
    instagramUrl={photographer.instagramUrl} instagramPosts={instagramPosts}
  />
</BaseLayout>
