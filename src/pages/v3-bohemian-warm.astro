---
import BaseLayout from '../layouts/BaseLayout.astro';
import SharedNav from '../components/shared/SharedNav.astro';
import Hero from '../components/v3/Hero.astro';
import Galleries from '../components/v3/Galleries.astro';
import About from '../components/v3/About.astro';
import Services from '../components/v3/Services.astro';
import SharedInvestmentGuide from '../components/shared/SharedInvestmentGuide.astro';
import SharedTestimonials from '../components/shared/SharedTestimonials.astro';
import SharedProcess from '../components/shared/SharedProcess.astro';
import SharedInquiryForm from '../components/shared/SharedInquiryForm.astro';
import SharedFooter from '../components/shared/SharedFooter.astro';

import { photographer } from '../data/v3/photographer';
import { galleries } from '../data/v3/galleries';
import { packages, investmentGuide } from '../data/v3/packages';
import { testimonials } from '../data/v3/testimonials';

const galleriesJson = JSON.stringify(galleries);

const instagramPosts = [
  { src: '/images/1519741497674-611481863552-400.webp', alt: 'Couple in flowing wedding attire on a Pacific coast beach at sunset' },
  { src: '/images/1522413452208-996ff3f3e740-400.webp', alt: 'Newlyweds at the rim of Crater Lake, Oregon' },
  { src: '/images/1591604466107-ec97de577aff-400.webp', alt: 'Bride twirling among ancient redwood trees' },
  { src: '/images/1537633552985-df8429e8048b-400.webp', alt: 'Couple in wildflower meadows below Mt. Rainier' },
  { src: '/images/1606800052052-a08af7148866-400.webp', alt: 'Elopement couple in the Columbia River Gorge' },
  { src: '/images/1583939003579-730e3918a45a-400.webp', alt: 'Couple embracing at Haystack Rock at Cannon Beach, Oregon' },
];
---
<BaseLayout
  title={`${photographer.business} | ${photographer.subtagline}`}
  description={`${photographer.tagline} ${photographer.subtagline}.`}
  ogImage={photographer.heroImage}
  themeClass="theme-v3"
  heroPreload={photographer.heroImage}
>
  <SharedNav name={photographer.name} variant="v3" />
  <main id="main-content">
    <Hero
      name={photographer.name}
      subtagline={photographer.subtagline}
      tagline={photographer.tagline}
      heroImage={photographer.heroImage}
      heroImageAlt={photographer.heroImageAlt}
    />
    <Galleries galleries={galleries} galleriesJson={galleriesJson} />
    <About
      name={photographer.name}
      portraitImage={photographer.portraitImage}
      portraitAlt={photographer.portraitAlt}
      aboutParagraph1={photographer.aboutParagraph1}
      aboutParagraph2={photographer.aboutParagraph2}
      philosophyQuote={photographer.philosophyQuote}
      philosophyAuthor={photographer.philosophyAuthor}
    />
    <Services packages={packages} />
    <SharedInvestmentGuide headline={investmentGuide.headline} subline={investmentGuide.subline} ctaLabel={investmentGuide.ctaLabel} />
    <SharedTestimonials testimonials={testimonials} label="Love Letters" heading="Kind words from adventurers" />
    <SharedProcess steps={photographer.process} label="The Adventure" heading="How It Goes" />
    <SharedInquiryForm
      name={photographer.name} email={photographer.email}
      location={photographer.location} instagramUrl={photographer.instagramUrl}
      instagram={photographer.instagram}
      heading="Let's plan your adventure"
      subheading="Tell us where you want to go. We'll figure out the rest together."
      submitLabel="Start the Adventure"
    />
  </main>
  <SharedFooter
    name={photographer.name} business={photographer.business}
    subtagline={photographer.subtagline} instagram={photographer.instagram}
    instagramUrl={photographer.instagramUrl} instagramPosts={instagramPosts}
  />
</BaseLayout>
