---
interface Props {
  name: string;
  subtagline: string;
  tagline: string;
  heroImage: string;
  heroImageAlt: string;
}
const { name, subtagline, tagline, heroImage, heroImageAlt } = Astro.props;
---

<!-- V4: Swiss 50/50 split — extreme whitespace left, full-height photo right -->
<section id="hero" class="relative flex min-h-screen overflow-hidden" style="background:var(--c-bg)" aria-label="Hero">

  <!-- Left: radical whitespace, ultra-large type -->
  <div class="relative z-10 w-full lg:w-1/2 flex flex-col justify-center px-10 lg:px-20 py-24 min-h-screen">

    <!-- Top metadata line -->
    <div class="mb-16 fade-hidden" style="transition-delay:0.1s">
      <p class="text-[9px] uppercase tracking-[0.5em] font-light" style="color:var(--c-text-muted)">{subtagline}</p>
    </div>

    <!-- The name — enormous, black, thin -->
    <h1 class="leading-[0.9] mb-12 fade-hidden" style="font-family:var(--f-display);font-size:clamp(3rem,7vw,8.5rem);color:var(--c-text);font-weight:400;letter-spacing:-0.03em;transition-delay:0.25s">
      {name.split(' ').map((word, i) => (
        <span class="block">{word}</span>
      ))}
    </h1>

    <!-- Thin horizontal rule -->
    <div class="w-full mb-8 fade-hidden" style="height:1px;background:var(--c-text);opacity:0.12;transition-delay:0.4s" aria-hidden="true"></div>

    <!-- Tagline -->
    <p class="text-sm lg:text-base font-light leading-relaxed mb-16 max-w-xs fade-hidden" style="color:var(--c-text-muted);font-family:var(--f-body);transition-delay:0.5s">
      {tagline}
    </p>

    <!-- CTA: ultra-minimal -->
    <div class="flex items-center gap-6 fade-hidden" style="transition-delay:0.65s">
      <a href="#galleries" class="text-[10px] uppercase tracking-[0.3em] transition-colors" style="color:var(--c-text)">
        View Portfolio →
      </a>
    </div>

    <!-- Bottom: year decoration -->
    <div class="absolute bottom-10 left-10 lg:left-20 fade-hidden" style="transition-delay:0.8s" aria-hidden="true">
      <p class="text-[9px] uppercase tracking-[0.4em] font-light" style="color:var(--c-text-muted)">Est. 2015</p>
    </div>
  </div>

  <!-- Right: full-height photo, flush edge -->
  <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-1/2">
    <img src={heroImage} alt={heroImageAlt}
      class="w-full h-full object-cover"
      loading="eager" fetchpriority="high" decoding="async" />
  </div>

  <!-- Mobile: overlay photo -->
  <div class="lg:hidden absolute inset-0 -z-10">
    <img src={heroImage} alt={heroImageAlt} class="w-full h-full object-cover" style="opacity:0.12" loading="eager" fetchpriority="high" decoding="async" />
  </div>
</section>
