---
import type { Package } from '../../data/v1/packages';
interface Props { packages: Package[]; }
const { packages } = Astro.props;
---

<!-- V4: Architectural three-column with huge price numbers — extreme restraint -->
<section id="services" class="py-24 lg:py-40" style="background:var(--c-bg-accent)" aria-label="Services and pricing">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <!-- Header: single thin line + label + title -->
    <div class="mb-20 lg:mb-32 fade-hidden">
      <div class="flex items-center gap-4 mb-6">
        <span class="w-8 h-px" style="background:var(--c-text-muted)" aria-hidden="true"></span>
        <p class="text-[9px] uppercase tracking-[0.5em] font-light" style="color:var(--c-text-muted)">Collections</p>
      </div>
      <h2 class="leading-none" style="font-family:var(--f-display);font-size:clamp(2.5rem,5vw,5rem);color:var(--c-text);font-weight:400">Investment</h2>
    </div>

    <!-- Three-column: bare minimum styling -->
    <div class="grid grid-cols-1 lg:grid-cols-3">
      {packages.map((pkg, i) => (
        <div class={`fade-hidden p-8 lg:p-10 flex flex-col ${i < packages.length - 1 ? 'lg:border-r' : ''} ${pkg.featured ? '' : ''}`}
          style={`border-color:rgba(0,0,0,0.08);transition-delay:${i*0.1}s;${pkg.featured ? 'background:var(--c-bg)' : ''}`}>

          <!-- Collection number -->
          <p class="text-[9px] uppercase tracking-[0.4em] mb-6 font-light" style="color:var(--c-text-muted)">0{i+1}</p>

          <!-- Name -->
          <h3 class="mb-2" style="font-family:var(--f-display);font-size:2rem;color:var(--c-text);font-weight:400">{pkg.name}</h3>
          <p class="text-xs uppercase tracking-widest mb-8 font-light" style="color:var(--c-text-muted)">{pkg.hours}</p>

          <!-- Includes as a sparse list -->
          <ul class="space-y-3 flex-1 mb-12" aria-label={`Includes in ${pkg.name}`}>
            {pkg.highlights.map(item => (
              <li class="flex items-start gap-3 text-sm font-light" style="color:var(--c-text-muted)">
                <span class="mt-1.5 w-3 h-px flex-shrink-0" style="background:var(--c-text-muted)" aria-hidden="true"></span>
                {item}
              </li>
            ))}
          </ul>

          <!-- Price: enormous, prominent -->
          <div class="border-t pt-8" style="border-color:rgba(0,0,0,0.08)">
            <p class="text-[9px] uppercase tracking-[0.35em] mb-1 font-light" style="color:var(--c-text-muted)">Starting at</p>
            <p class="leading-none mb-8" style="font-family:var(--f-display);font-size:3.5rem;color:var(--c-text);font-weight:400">{pkg.startingAt}</p>
            <a href="#inquire"
              class="inline-block text-[9px] uppercase tracking-[0.3em] px-6 py-3 transition-all duration-300 font-light"
              style={`border:1px solid var(--c-text);color:var(--c-text);` + (pkg.featured ? `background:var(--c-text);color:white` : '')}>
              Inquire
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
