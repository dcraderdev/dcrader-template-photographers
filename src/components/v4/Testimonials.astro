---
// V4 — Modern minimal
// Bibliography-style numbered references. No images, no cards. Hairline rules,
// monospaced numbering, Noto Serif quotes. Reads like a printed appendix.
import type { Testimonial } from '../../data/v4/testimonials';

interface Props { testimonials: Testimonial[]; }
const { testimonials } = Astro.props;
---

<section id="testimonials" class="py-28 lg:py-44" style="background:var(--c-bg)" aria-label="Client references">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <!-- Section header -->
    <div class="flex items-start gap-6 mb-24 fade-hidden">
      <span class="block w-px h-12 mt-2" style="background:var(--c-border)" aria-hidden="true"></span>
      <div>
        <p class="text-[7px] uppercase tracking-[0.6em] font-light mb-2" style="color:var(--c-text-muted);font-family:var(--f-body)">
          Appendix · References
        </p>
        <h2
          style="font-family:var(--f-body);font-size:clamp(1.6rem,3vw,3rem);color:var(--c-text);font-weight:300;letter-spacing:-0.04em"
        >
          What clients have said,<br />in their own words.
        </h2>
      </div>
    </div>

    <!-- Two-column ordered list — print-bibliography feel -->
    <ol
      class="grid grid-cols-1 lg:grid-cols-2 gap-x-16 gap-y-0"
      style="list-style:none;padding:0;margin:0"
      aria-label="Numbered client references"
    >
      {testimonials.map((t, i) => (
        <li
          class="py-10 fade-hidden"
          style={`border-top:1px solid var(--c-border);transition-delay:${i*0.08}s`}
        >
          <p
            class="text-[10px] tracking-[0.3em] mb-4"
            style="font-family:var(--f-body);color:var(--c-text-muted);font-variant-numeric:tabular-nums"
          >
            REF · {String(i+1).padStart(3,'0')}
          </p>
          <blockquote
            class="leading-loose italic mb-6"
            style="font-family:var(--f-serif);font-size:clamp(0.95rem,1.2vw,1.05rem);color:var(--c-text);font-weight:300"
          >
            &ldquo;{t.quote}&rdquo;
          </blockquote>
          <footer class="flex items-baseline gap-4">
            <span class="block w-4 h-px" style="background:var(--c-text);opacity:0.4" aria-hidden="true"></span>
            <p class="text-[10px] uppercase tracking-[0.5em] font-light" style="color:var(--c-text);font-family:var(--f-body)">
              {t.name} <span class="opacity-50">· {t.weddingInfo}</span>
            </p>
          </footer>
        </li>
      ))}
    </ol>

    <p
      class="mt-16 text-[7px] uppercase tracking-[0.6em] font-light fade-hidden"
      style="color:var(--c-text-muted);font-family:var(--f-body)"
    >
      Verbatim. Unedited. Reproduced with consent.
    </p>
  </div>
</section>
