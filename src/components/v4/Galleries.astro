---
import type { Gallery } from '../../data/v1/galleries';
interface Props { galleries: Gallery[]; galleriesJson: string; }
const { galleries, galleriesJson } = Astro.props;
---

<script id="galleries-data" type="application/json" set:html={galleriesJson}></script>

<!-- V4: Flush square grid, no gaps, architectural precision -->
<section id="galleries" class="py-24 lg:py-40" style="background:var(--c-bg)" aria-label="Featured galleries">

  <!-- Header: minimal, left-aligned -->
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16 mb-16 fade-hidden">
    <div class="flex items-end gap-8">
      <span class="block w-px h-12" style="background:var(--c-text);opacity:0.2" aria-hidden="true"></span>
      <div>
        <p class="text-[9px] uppercase tracking-[0.45em] mb-2 font-light" style="color:var(--c-text-muted)">Portfolio</p>
        <h2 style="font-family:var(--f-display);font-size:clamp(2rem,4vw,4rem);color:var(--c-text);font-weight:400">Selected Work</h2>
      </div>
    </div>
  </div>

  <!-- Flush 3×2 square grid with no gap — the photos touch -->
  <div class="grid grid-cols-2 lg:grid-cols-3" style="gap:2px">
    {galleries.map((gallery, i) => (
      <button
        class="gallery-card group relative overflow-hidden aspect-square fade-hidden cursor-pointer"
        style={`transition-delay:${i*0.06}s`}
        aria-label={`Open ${gallery.title} gallery`}
        data-gallery-id={gallery.id}
        type="button"
      >
        <img src={gallery.coverImage} alt={gallery.coverAlt}
          class="w-full h-full object-cover transition-all duration-500 group-hover:opacity-75"
          loading="lazy" decoding="async" />
        <!-- Minimal text reveal -->
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-5"
          style="background:rgba(255,255,255,0.9)">
          <p class="text-[9px] uppercase tracking-[0.35em] mb-1" style="color:var(--c-text-muted)">{gallery.subtitle}</p>
          <p class="text-lg" style="font-family:var(--f-display);color:var(--c-text)">{gallery.title}</p>
        </div>
      </button>
    ))}
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="lightbox-overlay" role="dialog" aria-modal="true" aria-label="Gallery lightbox">
  <div class="w-full max-w-5xl py-8 lg:py-16">
    <button id="lightbox-close" class="fixed top-6 right-6 lg:top-8 lg:right-8 z-10 flex items-center gap-3 transition-colors"
      style="color:white" aria-label="Close gallery" type="button">
      <span class="text-xs uppercase tracking-widest font-light">Close</span>
      <span class="text-2xl leading-none" aria-hidden="true">×</span>
    </button>
    <div class="px-6 mb-10">
      <p id="lightbox-subtitle" class="text-[9px] uppercase tracking-[0.3em] mb-2" style="color:var(--c-accent)"></p>
      <h3 id="lightbox-title" class="text-3xl lg:text-5xl" style="font-family:var(--f-display);color:white;font-weight:400"></h3>
    </div>
    <div id="lightbox-images" class="flex flex-col gap-2 px-6"></div>
  </div>
</div>

<script>
  const galData = JSON.parse((document.getElementById('galleries-data') as HTMLScriptElement)?.text || '[]');
  const lightbox = document.getElementById('lightbox');
  const closeBtn = document.getElementById('lightbox-close');
  const titleEl = document.getElementById('lightbox-title');
  const subtitleEl = document.getElementById('lightbox-subtitle');
  const imagesEl = document.getElementById('lightbox-images');
  function openGallery(id: string) {
    const g = galData.find((x: { id: string }) => x.id === id);
    if (!g || !lightbox || !titleEl || !subtitleEl || !imagesEl) return;
    titleEl.textContent = g.title; subtitleEl.textContent = g.subtitle; imagesEl.innerHTML = '';
    g.images.forEach((img: { src: string; alt: string }) => {
      const el = document.createElement('img');
      el.src = img.src; el.alt = img.alt; el.className = 'w-full h-auto object-cover'; el.loading = 'lazy'; el.decoding = 'async';
      imagesEl.appendChild(el);
    });
    lightbox.classList.add('active'); document.body.style.overflow = 'hidden'; closeBtn?.focus();
  }
  function closeLightbox() { lightbox?.classList.remove('active'); document.body.style.overflow = ''; if (imagesEl) imagesEl.innerHTML = ''; }
  document.querySelectorAll('[data-gallery-id]').forEach(btn => {
    btn.addEventListener('click', () => { const id = (btn as HTMLElement).dataset.galleryId; if (id) openGallery(id); });
  });
  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
</script>
