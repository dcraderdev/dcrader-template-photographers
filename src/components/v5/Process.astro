---
// V5 — vibrant joyful
// Sticker stack: each step is a chunky colored bento tile with emoji + bold copy.
interface Step { number: string; title: string; description: string; }
interface Props { steps: Step[]; }
const { steps } = Astro.props;

const tileBgs = ['var(--c-accent)', 'var(--c-coral)', 'var(--c-text)', 'white'];
const tileFgs = ['var(--c-text)', 'white', 'white', 'var(--c-text)'];
const emojis = ['👋', '☎️', '📸', '💌'];
---

<section id="process" class="py-20 lg:py-28" style="background:var(--c-bg)" aria-label="How it works">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <div class="text-center mb-12 fade-hidden">
      <span
        class="inline-block text-xs font-bold uppercase tracking-wider px-4 py-2 mb-6 rotate-[-1deg]"
        style="background:var(--c-accent);color:var(--c-text);border-radius:0.5rem;font-family:var(--f-body)"
      >
        The Roadmap 🗺️
      </span>
      <h2
        class="font-bold leading-tight"
        style="font-family:var(--f-display);font-size:clamp(2.2rem,5vw,4rem);color:var(--c-text)"
      >
        Four steps. Zero stress.
      </h2>
    </div>

    <!-- Bento step grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      {steps.map((step, i) => {
        const bg = tileBgs[i % tileBgs.length];
        const fg = tileFgs[i % tileFgs.length];
        const tilt = i % 2 === 0 ? '-0.5deg' : '0.5deg';
        return (
          <article
            class="fade-hidden p-6 lg:p-7 flex flex-col h-full"
            style={`background:${bg};color:${fg};border-radius:var(--radius);transform:rotate(${tilt});transition-delay:${i*0.08}s;border:${bg === 'white' ? '1px solid var(--c-border)' : 'none'}`}
          >
            <div class="flex items-center justify-between mb-5">
              <span
                class="inline-flex items-center justify-center text-2xl"
                style={`width:48px;height:48px;background:${bg === 'white' || bg === 'var(--c-accent)' ? 'var(--c-text)' : 'white'};color:${bg === 'white' || bg === 'var(--c-accent)' ? 'white' : 'var(--c-text)'};border-radius:0.85rem`}
                aria-hidden="true"
              >
                {emojis[i % emojis.length]}
              </span>
              <p
                class="text-xs font-bold uppercase tracking-wider"
                style={`color:${fg};opacity:0.7;font-family:var(--f-body)`}
              >
                Step {step.number}
              </p>
            </div>
            <h3
              class="font-bold leading-tight mb-3"
              style={`font-family:var(--f-display);font-size:1.6rem;color:${fg}`}
            >
              {step.title}
            </h3>
            <p
              class="text-sm leading-relaxed flex-1 font-medium"
              style={`color:${fg};opacity:0.85;font-family:var(--f-body)`}
            >
              {step.description}
            </p>
          </article>
        );
      })}
    </div>
  </div>
</section>
