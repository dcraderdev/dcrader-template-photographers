---
// V5 footer — vibrant joyful.
// Sticker collage: tilted square IG tiles + a giant "DM us" CTA tile.
// Uses bento corner radius and color tiles. Playful end note.
import ResponsiveImage from '../shared/ResponsiveImage.astro';
interface Props {
  name: string;
  business: string;
  subtagline: string;
  instagram: string;
  instagramUrl: string;
  instagramPosts: Array<{ src: string; alt: string; }>;
}
const { name, business, subtagline, instagram, instagramUrl, instagramPosts } = Astro.props;
const photos = instagramPosts.slice(0, 5);
const rotations = ['-2deg', '1.5deg', '-1deg', '2.5deg', '-1.5deg'];
---

<footer style="background:var(--c-bg-accent);padding-top:5rem;padding-bottom:3rem" aria-label="Site footer">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <!-- Bento footer header tile -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 mb-10 fade-hidden">

      <!-- Big CTA tile -->
      <div
        class="lg:col-span-7 p-8 lg:p-12 flex flex-col justify-between"
        style="background:var(--c-text);color:white;border-radius:var(--radius);min-height:280px"
      >
        <span
          class="inline-block self-start text-[10px] font-bold uppercase tracking-wider px-3 py-1 rotate-[-2deg]"
          style="background:var(--c-accent);color:var(--c-text);border-radius:0.5rem;font-family:var(--f-body)"
        >
          DM us anytime 💌
        </span>
        <div>
          <h2
            class="font-bold leading-none mb-3"
            style="font-family:var(--f-display);font-size:clamp(2rem,4.5vw,3.6rem);color:white"
          >
            Don&rsquo;t be a stranger.
          </h2>
          <p class="text-base lg:text-lg font-medium mb-6" style="color:rgba(255,255,255,0.75);font-family:var(--f-body)">
            We answer every DM. We will absolutely send memes.
          </p>
          <a
            href={instagramUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block font-bold text-sm px-6 py-3 transition-all duration-300 hover:opacity-85"
            style="background:var(--c-coral);color:white;border-radius:9999px;font-family:var(--f-body)"
            aria-label={`Visit ${instagram} on Instagram (opens in new tab)`}
          >
            {instagram} →
          </a>
        </div>
      </div>

      <!-- Photo collage tile -->
      <div
        class="lg:col-span-5 p-6 flex flex-wrap items-center justify-center gap-3"
        style="background:var(--c-coral);border-radius:var(--radius);min-height:280px"
        role="list"
        aria-label="Recent Instagram posts"
      >
        {photos.map((post, i) => (
          <a
            href={instagramUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group block overflow-hidden transition-transform duration-300 hover:rotate-0 hover:scale-105"
            style={`width:90px;height:90px;border-radius:0.85rem;transform:rotate(${rotations[i % rotations.length]});border:3px solid white`}
            role="listitem"
            aria-label={`${post.alt} — view on Instagram (opens in new tab)`}
          >
            <ResponsiveImage src={post.src} alt={post.alt}
              class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </a>
        ))}
      </div>
    </div>

    <!-- Sign-off tile row -->
    <div
      class="p-7 lg:p-9 flex flex-col lg:flex-row items-center justify-between gap-6 fade-hidden"
      style="background:white;border-radius:var(--radius);transition-delay:0.15s"
    >
      <div class="text-center lg:text-left">
        <p
          class="font-bold leading-none"
          style="font-family:var(--f-display);font-size:1.6rem;color:var(--c-text)"
        >
          {name}
        </p>
        <p class="text-xs uppercase tracking-wider font-semibold mt-2" style="color:var(--c-coral);font-family:var(--f-body)">
          {subtagline}
        </p>
      </div>
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap justify-center gap-2" style="list-style:none;padding:0;margin:0">
          {[['#galleries','Work'],['#about','About'],['#services','Pricing'],['#inquire','Book Us']].map(([href, label]) => (
            <li>
              <a
                href={href}
                class="inline-block text-xs font-bold uppercase tracking-wider px-4 py-2 transition-all duration-200 hover:opacity-80"
                style="background:var(--c-bg-accent);color:var(--c-text);border-radius:9999px;font-family:var(--f-body)"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <p class="text-center mt-8 text-xs font-bold uppercase tracking-wider" style="color:var(--c-text);font-family:var(--f-body);opacity:0.6">
      © {new Date().getFullYear()} {business} · made with confetti 🎊
    </p>
    <p class="text-center mt-3 text-[10px]" style="color:var(--c-text);opacity:0.5">
      Built by <a href="https://dcrader.dev" target="_blank" rel="noopener noreferrer" class="underline" style="color:var(--c-coral)">Donovan Crader</a> · <a href="https://dcrader.dev" target="_blank" rel="noopener noreferrer" style="color:var(--c-coral)">dcrader.dev</a>
    </p>
  </div>
</footer>
