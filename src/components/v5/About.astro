---
import ResponsiveImage from '../shared/ResponsiveImage.astro';
interface Props {
  name: string; portraitImage: string; portraitAlt: string;
  aboutParagraph1: string; aboutParagraph2: string;
  philosophyQuote: string; philosophyAuthor: string;
}
const p = Astro.props;
---

<!-- V5: Bento-style about — yellow, coral, white tiles + floating heart -->
<section id="about" class="py-20 lg:py-32" style="background:var(--c-bg-accent)" aria-label={`About ${p.name}`}>
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <!-- Section sticker label -->
    <div class="mb-10 fade-hidden">
      <span
        class="inline-block text-xs font-bold uppercase tracking-wider px-4 py-2 rotate-[-1.5deg]"
        style="background:var(--c-coral);color:white;border-radius:0.5rem;font-family:var(--f-body)"
        aria-label="About Us section"
      >
        About Us 🙌
      </span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-5">

      <!-- Portrait tile: tall, yellow shadow -->
      <div class="lg:col-span-4 relative fade-hidden">
        <div class="absolute inset-0 -z-10" style="background:var(--c-accent);border-radius:var(--radius);transform:translate(10px,10px)" aria-hidden="true"></div>
        <div class="overflow-hidden" style="border-radius:var(--radius);aspect-ratio:4/5">
          <ResponsiveImage src={p.portraitImage} alt={p.portraitAlt}
            class="w-full h-full object-cover" loading="lazy" decoding="async" />
        </div>
        <!-- Floating heart badge -->
        <div class="absolute -top-4 -right-4 heart-beat" aria-hidden="true">
          <svg width="44" height="40" viewBox="0 0 44 40" fill="none">
            <path d="M22 36 C17 30, 4 23, 4 12 C4 6.5, 8.5 3, 13 3 C16.5 3, 19.5 5, 22 7.5 C24.5 5, 27.5 3, 31 3 C35.5 3, 40 6.5, 40 12 C40 23, 27 30, 22 36Z" fill="var(--c-coral)"/>
          </svg>
        </div>
      </div>

      <!-- Text tile -->
      <div class="lg:col-span-8 fade-hidden" style="transition-delay:0.12s">
        <div class="p-8 lg:p-10 h-full" style="background:white;border-radius:var(--radius)">
          <h2 class="font-bold leading-tight mb-6" style="font-family:var(--f-display);font-size:clamp(2rem,4vw,3rem);color:var(--c-text)">
            We show up<br />for the party 🎉
          </h2>
          <div class="space-y-4 text-sm lg:text-base leading-relaxed mb-8" style="color:var(--c-text-muted);font-family:var(--f-body)">
            <p set:html={p.aboutParagraph1}></p>
            <p set:html={p.aboutParagraph2}></p>
          </div>

          <!-- Quote sticker bubble -->
          <div class="p-5" style="background:var(--c-bg-accent);border-radius:1rem">
            <figure>
              <blockquote class="text-base font-medium leading-relaxed" style="font-family:var(--f-display);color:var(--c-text)">
                "{p.philosophyQuote}"
              </blockquote>
              <figcaption class="mt-3 text-xs font-semibold uppercase tracking-wider" style="color:var(--c-coral);font-family:var(--f-body)">
                — {p.philosophyAuthor}
              </figcaption>
            </figure>
          </div>
        </div>
      </div>

      <!-- Behind-the-scenes journal teaser -->
      <div class="lg:col-span-12 fade-hidden" style="transition-delay:0.22s">
        <div class="flex items-center justify-between mb-5 flex-wrap gap-3">
          <h3
            class="font-bold leading-tight"
            style="font-family:var(--f-display);font-size:clamp(1.4rem,2.5vw,2rem);color:var(--c-text)"
          >
            From the journal 📓
          </h3>
          <a
            href="#inquiry"
            class="text-xs font-bold uppercase tracking-wider px-4 py-2"
            style="background:var(--c-text);color:white;border-radius:0.5rem;font-family:var(--f-body)"
          >
            Read more on Instagram →
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {[
            {
              img: '/images/1583939003579-730e3918a45a-800.webp',
              alt: 'Petal toss exit at a Hill Country reception',
              tag: 'Backstage',
              tagBg: 'var(--c-coral)',
              date: 'Apr 12',
              title: 'The petal toss that almost wasn’t',
              snippet: 'Wind shifted three minutes before the exit. Plan B involved sixty guests, two flower girls, and a leaf blower.',
            },
            {
              img: '/images/1525772764200-be829a350797-800.webp',
              alt: 'Vendor meal during a long Austin wedding day',
              tag: 'Gear & Snacks',
              tagBg: 'var(--c-accent)',
              date: 'Mar 28',
              title: 'What lives in our camera bag at hour 11',
              snippet: 'Two backup bodies, four primes, fresh batteries, breath mints, and a granola bar older than this business.',
            },
            {
              img: '/images/1606800052052-a08af7148866-800.webp',
              alt: 'First dance under string lights at an Austin reception',
              tag: 'Real Talk',
              tagBg: 'var(--c-text)',
              date: 'Mar 14',
              title: 'A first dance, two left feet, one perfect frame',
              snippet: 'Tomás nearly tripped on the dance floor cable. The shot we got is on our office wall.',
            },
          ].map((p, i) => (
            <article
              class="overflow-hidden flex flex-col"
              style={`background:white;border-radius:var(--radius);transform:rotate(${i === 1 ? '0.6deg' : i === 2 ? '-0.4deg' : '0deg'})`}
            >
              <div class="relative" style="aspect-ratio:4/3">
                <ResponsiveImage
                  src={p.img}
                  alt={p.alt}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
                <span
                  class="absolute top-3 left-3 text-[10px] font-bold uppercase tracking-wider px-3 py-1"
                  style={`background:${p.tagBg};color:${p.tagBg === 'var(--c-text)' ? 'white' : 'var(--c-text)'};border-radius:999px;font-family:var(--f-body)`}
                >
                  {p.tag}
                </span>
              </div>
              <div class="p-5 flex-1 flex flex-col">
                <p
                  class="text-[10px] uppercase tracking-[0.25em] mb-2"
                  style="color:var(--c-coral);font-family:var(--f-body);font-weight:700"
                >
                  Journal · {p.date}
                </p>
                <h4
                  class="font-bold leading-snug mb-2"
                  style="font-family:var(--f-display);font-size:1.1rem;color:var(--c-text)"
                >
                  {p.title}
                </h4>
                <p
                  class="text-sm leading-relaxed flex-1"
                  style="color:var(--c-text-muted);font-family:var(--f-body)"
                >
                  {p.snippet}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

