---
interface Props {
  name: string;
  subtagline: string;
  tagline: string;
  heroImage: string;
  heroImageAlt: string;
}
const { name, subtagline, tagline, heroImage, heroImageAlt } = Astro.props;
---

<!-- V5: Yellow left panel + rounded-corner photo, celebration energy -->
<section id="hero" class="min-h-screen flex items-center overflow-hidden" style="background:var(--c-bg)" aria-label="Hero">
  <div class="w-full max-w-screen-xl mx-auto px-6 lg:px-16 py-24 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

    <!-- Left: yellow background panel with bold text -->
    <div class="relative">
      <!-- Big yellow accent blob behind -->
      <div class="absolute -inset-4 lg:-inset-8 -z-10 rounded-2xl" style="background:var(--c-accent)" aria-hidden="true"></div>

      <div class="relative z-10 p-8 lg:p-10">
        <p class="text-xs uppercase tracking-[0.3em] font-semibold mb-6" style="color:rgba(26,26,26,0.6)">{subtagline}</p>
        <h1 class="leading-tight mb-6 fade-hidden" style="font-family:var(--f-display);font-size:clamp(2.8rem,6vw,5.5rem);color:var(--c-text);font-weight:700;letter-spacing:-0.02em;transition-delay:0.2s">
          {name}
        </h1>
        <p class="text-lg lg:text-xl font-medium mb-10 fade-hidden" style="color:rgba(26,26,26,0.7);transition-delay:0.35s">
          {tagline}
        </p>
        <div class="flex flex-wrap gap-4 fade-hidden" style="transition-delay:0.5s">
          <a href="#galleries"
            class="text-sm font-semibold uppercase tracking-wide px-8 py-3.5 transition-all duration-300"
            style="background:var(--c-text);color:white;border-radius:9999px">
            See Our Work
          </a>
          <a href="#inquire"
            class="text-sm font-semibold uppercase tracking-wide px-8 py-3.5 transition-all duration-300"
            style="border:2px solid var(--c-text);color:var(--c-text);border-radius:9999px">
            Book Us
          </a>
        </div>
      </div>
    </div>

    <!-- Right: photo with rounded corners -->
    <div class="relative fade-hidden" style="transition-delay:0.15s">
      <div class="overflow-hidden" style="border-radius:1.5rem;aspect-ratio:4/5">
        <img src={heroImage} alt={heroImageAlt}
          class="w-full h-full object-cover ken-burns"
          loading="eager" fetchpriority="high" decoding="async" />
      </div>
      <!-- Floating confetti dot decorations -->
      <div class="absolute -top-4 -right-4 w-12 h-12 rounded-full opacity-60" style="background:#FF6B6B" aria-hidden="true"></div>
      <div class="absolute -bottom-4 -left-4 w-8 h-8 rounded-full opacity-60" style="background:var(--c-accent)" aria-hidden="true"></div>
      <div class="absolute top-1/3 -right-6 w-5 h-5 rounded-full opacity-50" style="background:#FF6B6B" aria-hidden="true"></div>
    </div>
  </div>
</section>
