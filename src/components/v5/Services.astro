---
import type { Package } from '../../data/v1/packages';
interface Props { packages: Package[]; }
const { packages } = Astro.props;
const configs = [
  { bg: 'var(--c-bg-accent)', emoji: '✨', cta: 'Let\'s Do It →' },
  { bg: 'var(--c-accent)',    emoji: '🎉', cta: 'Book Us →' },
  { bg: '#FFE8E2',            emoji: '🎊', cta: 'Let\'s Party →' },
];
---

<!-- V5: Sticker-style package cards, Fraunces headings, coral/yellow/cream -->
<section id="services" class="py-20 lg:py-32" style="background:var(--c-bg)" aria-label="Services and pricing">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <div class="text-center mb-14 fade-hidden">
      <!-- Floating camera SVG above heading -->
      <div class="inline-block mb-4 float-up" aria-hidden="true">
        <svg width="40" height="34" viewBox="0 0 40 34" fill="none">
          <rect x="2" y="8" width="36" height="24" rx="4" fill="var(--c-coral)" opacity="0.7"/>
          <rect x="13" y="2" width="14" height="8" rx="2" fill="var(--c-coral)" opacity="0.7"/>
          <circle cx="20" cy="20" r="8" fill="white" opacity="0.5"/>
          <circle cx="20" cy="20" r="4.5" fill="white" opacity="0.4"/>
          <circle cx="7" cy="12" r="2" fill="white" opacity="0.6"/>
        </svg>
      </div>
      <p class="text-xs font-semibold uppercase tracking-[0.3em] mb-3" style="color:var(--c-coral);font-family:var(--f-body)">Let's Party</p>
      <h2 class="font-bold leading-tight" style="font-family:var(--f-display);font-size:clamp(2.5rem,5vw,4rem);color:var(--c-text)">
        Pick Your Vibe
      </h2>
      <p class="mt-3 text-base font-medium" style="color:var(--c-text-muted);font-family:var(--f-body)">
        Every package made for real humans who love to celebrate 🙌
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 lg:gap-6 items-start">
      {packages.map((pkg, i) => {
        const c = configs[i] || configs[0];
        const isMiddle = pkg.featured;
        return (
          <div
            class={`relative flex flex-col p-8 lg:p-10 fade-hidden ${isMiddle ? 'md:-mt-4 md:shadow-2xl' : 'shadow-sm hover:shadow-xl'} transition-shadow duration-300`}
            style={`background:${c.bg};border-radius:1.5rem;transition-delay:${i*0.1}s`}
          >
            {isMiddle && (
              <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2">
                <span class="text-[9px] font-bold uppercase tracking-wide px-5 py-1.5" style="background:var(--c-coral);color:white;border-radius:9999px;font-family:var(--f-body)">
                  Most Popular 🎉
                </span>
              </div>
            )}

            <!-- Emoji sticker -->
            <div class="text-4xl mb-5 wiggle inline-block" style="animation-delay:{i*0.5}s" aria-hidden="true">{c.emoji}</div>

            <p class="text-[9px] uppercase tracking-[0.3em] font-semibold mb-2" style="color:rgba(26,26,26,0.45);font-family:var(--f-body)">Package</p>
            <h3 class="font-bold mb-3 leading-tight" style="font-family:var(--f-display);font-size:clamp(1.8rem,3vw,2.2rem);color:var(--c-text)">{pkg.name}</h3>
            <p class="text-sm leading-relaxed mb-4 font-medium" style="color:rgba(26,26,26,0.6);font-family:var(--f-body)">{pkg.description}</p>

            <!-- Hours pill -->
            <span class="inline-block text-[9px] font-bold uppercase tracking-wide px-3 py-1.5 mb-6 self-start" style="background:rgba(0,0,0,0.08);border-radius:9999px;color:rgba(26,26,26,0.65);font-family:var(--f-body)">
              {pkg.hours}
            </span>

            <ul class="space-y-3 flex-1 mb-8" aria-label={`Included in ${pkg.name}`}>
              {pkg.highlights.map(item => (
                <li class="flex items-start gap-3 text-sm font-medium" style="color:rgba(26,26,26,0.75);font-family:var(--f-body)">
                  <span class="font-bold flex-shrink-0 mt-0.5" style="color:var(--c-coral)" aria-hidden="true">✓</span>
                  {item}
                </li>
              ))}
            </ul>

            <div class="pt-6" style="border-top:2px solid rgba(0,0,0,0.07)">
              <p class="text-[9px] uppercase tracking-wider mb-1 font-semibold" style="color:rgba(26,26,26,0.4);font-family:var(--f-body)">Starting at</p>
              <p class="font-bold leading-none mb-6" style="font-family:var(--f-display);font-size:clamp(2.5rem,4vw,3rem);color:var(--c-text)">{pkg.startingAt}</p>
              <a href="#inquire"
                class="block text-center font-bold text-sm uppercase tracking-wide py-3.5 transition-all duration-300 hover:opacity-85"
                style="background:var(--c-text);color:white;border-radius:9999px;font-family:var(--f-body)">
                {c.cta}
              </a>
            </div>
          </div>
        );
      })}
    </div>

    <p class="text-center mt-10 font-medium text-sm fade-hidden" style="color:var(--c-text-muted);font-family:var(--f-body);transition-delay:0.4s">
      Travel included everywhere in Texas 🤠 · Destination quotes are just a DM away
    </p>
  </div>
</section>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('fade-visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-hidden').forEach(el => obs.observe(el));
</script>
