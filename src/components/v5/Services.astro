---
import type { Package } from '../../data/v1/packages';
interface Props { packages: Package[]; }
const { packages } = Astro.props;
const icons = ['✨', '🎉', '🎊'];
const cardBgs = ['var(--c-bg-accent)', 'var(--c-accent)', '#FFE4E4'];
const textColors = ['var(--c-text)', 'var(--c-text)', 'var(--c-text)'];
---

<!-- V5: Colorful rounded cards with emojis, celebration energy -->
<section id="services" class="py-24 lg:py-32" style="background:var(--c-bg)" aria-label="Services and pricing">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <div class="text-center mb-16 lg:mb-20 fade-hidden">
      <p class="text-xs uppercase tracking-[0.3em] font-semibold mb-4" style="color:var(--c-accent-dark)">Let's Party</p>
      <h2 class="font-bold" style="font-family:var(--f-display);font-size:clamp(2.5rem,5vw,4.5rem);color:var(--c-text)">
        Pick Your Vibe
      </h2>
      <p class="mt-4 text-sm max-w-md mx-auto" style="color:var(--c-text-muted)">
        Every package is designed for real people who want real moments captured.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {packages.map((pkg, i) => (
        <div class={`relative p-8 lg:p-10 flex flex-col fade-hidden ${pkg.featured ? 'md:scale-105 md:shadow-2xl' : 'shadow-sm hover:shadow-lg'}`}
          style={`background:${cardBgs[i]};border-radius:1.5rem;transition:box-shadow 0.3s ease;transition-delay:${i*0.1}s`}>

          {pkg.featured && (
            <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 px-5 py-1.5 text-[9px] font-bold uppercase tracking-wider"
              style="background:#FF6B6B;color:white;border-radius:9999px">
              Most Popular
            </div>
          )}

          <!-- Emoji icon -->
          <div class="text-4xl mb-5" aria-hidden="true">{icons[i]}</div>

          <p class="text-[10px] uppercase tracking-[0.25em] font-semibold mb-2" style="color:rgba(26,26,26,0.5)">Package</p>
          <h3 class="font-bold text-3xl mb-3" style={`font-family:var(--f-display);color:${textColors[i]}`}>{pkg.name}</h3>
          <p class="text-sm leading-relaxed mb-5" style="color:rgba(26,26,26,0.6)">{pkg.description}</p>
          <p class="text-xs font-semibold uppercase tracking-wide mb-6 px-3 py-1.5 inline-block" style="background:rgba(0,0,0,0.08);border-radius:9999px;color:rgba(26,26,26,0.7)">{pkg.hours}</p>

          <ul class="space-y-3 flex-1 mb-8" aria-label={`Included in ${pkg.name}`}>
            {pkg.highlights.map(item => (
              <li class="flex items-start gap-3 text-sm" style="color:rgba(26,26,26,0.75)">
                <span class="font-bold flex-shrink-0" style="color:#FF6B6B" aria-hidden="true">✓</span>
                {item}
              </li>
            ))}
          </ul>

          <div class="pt-6" style="border-top:2px solid rgba(0,0,0,0.08)">
            <p class="text-[10px] uppercase tracking-wider mb-1 font-semibold" style="color:rgba(26,26,26,0.45)">Starting at</p>
            <p class="text-4xl font-bold mb-6" style={`font-family:var(--f-display);color:${textColors[i]}`}>{pkg.startingAt}</p>
            <a href="#inquire"
              class="block text-center text-sm font-bold uppercase tracking-wide py-4 transition-all duration-300"
              style={`background:var(--c-text);color:white;border-radius:9999px`}>
              Let's Do It →
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
