---
import type { Gallery } from '../../data/v1/galleries';
import ResponsiveImage from '../shared/ResponsiveImage.astro';
interface Props { galleries: Gallery[]; galleriesJson: string; }
const { galleries, galleriesJson } = Astro.props;

// Bento grid spans: each tile gets different column/row spans for visual variety
const bentoConfig = [
  { cols: 'lg:col-span-4', rows: 'lg:row-span-2', aspect: 'aspect-[3/4]' },  // Tall left tile
  { cols: 'lg:col-span-4', rows: 'lg:row-span-1', aspect: 'aspect-[4/3]' },  // Right top
  { cols: 'lg:col-span-4', rows: 'lg:row-span-1', aspect: 'aspect-[4/3]' },  // Right bottom
  { cols: 'lg:col-span-6', rows: 'lg:row-span-1', aspect: 'aspect-[16/9]' }, // Wide
  { cols: 'lg:col-span-3', rows: 'lg:row-span-1', aspect: 'aspect-square' }, // Small
  { cols: 'lg:col-span-3', rows: 'lg:row-span-1', aspect: 'aspect-square' }, // Small
];
const overlayColors = ['var(--c-accent)', 'var(--c-coral)', 'var(--c-accent)', 'var(--c-coral)', 'var(--c-accent)', 'var(--c-coral)'];
---

<script id="galleries-data" type="application/json" set:html={galleriesJson}></script>

<!-- V5: True CSS bento grid — different tile sizes, yellow/coral hover overlays -->
<section id="galleries" class="py-20 lg:py-32" style="background:var(--c-bg)" aria-label="Featured galleries">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <!-- Header: Fraunces + Manrope -->
    <div class="mb-12 lg:mb-16 fade-hidden">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.3em] mb-2" style="color:var(--c-accent-dark);font-family:var(--f-body)">Our Work</p>
          <h2 class="leading-none" style="font-family:var(--f-display);font-size:clamp(2.5rem,5vw,4rem);color:var(--c-text);font-weight:400">
            Real Celebrations
          </h2>
        </div>
        <!-- Floating heart decoration -->
        <div class="hidden lg:block float-up" aria-hidden="true">
          <svg width="48" height="44" viewBox="0 0 48 44" fill="none">
            <path d="M24 40 C18 34, 4 26, 4 14 C4 7.5, 8.5 4, 13.5 4 C17 4, 20.5 5.5, 24 8.5 C27.5 5.5, 31 4, 34.5 4 C39.5 4, 44 7.5, 44 14 C44 26, 30 34, 24 40Z" fill="var(--c-coral)" opacity="0.6"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Bento grid: desktop 12-col, mobile stacked -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 lg:grid-rows-3 gap-4 lg:gap-5">
      {galleries.map((gallery, i) => {
        const b = bentoConfig[i] || bentoConfig[i % 6];
        const overlay = overlayColors[i % 2];
        return (
          <button
            class={`gallery-card group relative overflow-hidden cursor-pointer text-left fade-hidden col-span-1 ${b.cols} ${b.rows} ${b.aspect}`}
            style={`border-radius:var(--radius);transition-delay:${i*0.07}s`}
            aria-label={`Open ${gallery.title} gallery`}
            data-gallery-id={gallery.id}
            type="button"
          >
            <ResponsiveImage
              src={gallery.coverImage}
              alt={gallery.coverAlt}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
            <!-- Colored overlay on hover -->
            <div
              class="absolute inset-0 opacity-0 group-hover:opacity-90 transition-opacity duration-400 flex flex-col justify-end p-5 lg:p-6"
              style={`background:${overlay}`}
            >
              <p class="text-[9px] uppercase tracking-[0.3em] mb-1 font-semibold" style="color:rgba(26,26,26,0.6);font-family:var(--f-body)">{gallery.subtitle}</p>
              <p class="font-bold leading-tight" style="font-family:var(--f-display);font-size:clamp(1.2rem,2.5vw,1.8rem);color:var(--c-text)">{gallery.title}</p>
            </div>

            <!-- Camera icon watermark (always visible, fades on hover) -->
            <div class="absolute top-3 right-3 opacity-40 group-hover:opacity-0 transition-opacity duration-300" aria-hidden="true">
              <svg width="20" height="17" viewBox="0 0 20 17" fill="none">
                <rect x="1" y="4" width="18" height="12" rx="2" fill="white" opacity="0.9"/>
                <rect x="7" y="1" width="6" height="4" rx="1" fill="white" opacity="0.9"/>
                <circle cx="10" cy="10" r="3.5" fill="rgba(0,0,0,0.3)" stroke="white" stroke-width="1"/>
              </svg>
            </div>
          </button>
        );
      })}
    </div>
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="lightbox-overlay" role="dialog" aria-modal="true" aria-label="Gallery lightbox">
  <div class="w-full max-w-5xl py-8 lg:py-16">
    <button id="lightbox-close"
      class="fixed top-6 right-6 lg:top-8 lg:right-8 z-10 flex items-center gap-2 font-semibold"
      style="color:white;font-family:var(--f-body);font-size:0.85rem;border-radius:9999px;background:rgba(255,255,255,0.12);padding:0.5rem 1rem"
      aria-label="Close gallery" type="button">
      Close ×
    </button>
    <div class="px-6 mb-10">
      <p id="lightbox-subtitle" class="text-xs uppercase tracking-[0.3em] mb-3 font-semibold" style="color:var(--c-accent);font-family:var(--f-body)"></p>
      <h3 id="lightbox-title" class="font-bold leading-none" style="font-family:var(--f-display);font-size:clamp(2rem,5vw,4rem);color:white"></h3>
    </div>
    <div id="lightbox-images" class="flex flex-col gap-4 px-6"></div>
  </div>
</div>

<script>
  const galData: { id: string; title: string; subtitle: string; images: { src: string; alt: string }[] }[] =
    JSON.parse((document.getElementById('galleries-data') as HTMLScriptElement)?.text || '[]');

  const lightbox = document.getElementById('lightbox');
  const closeBtn = document.getElementById('lightbox-close');
  const titleEl  = document.getElementById('lightbox-title');
  const subtitleEl = document.getElementById('lightbox-subtitle');
  const imagesEl = document.getElementById('lightbox-images');

  function openGallery(id: string) {
    const g = galData.find(x => x.id === id);
    if (!g || !lightbox || !titleEl || !subtitleEl || !imagesEl) return;
    titleEl.textContent = g.title;
    subtitleEl.textContent = g.subtitle;
    imagesEl.innerHTML = '';
    g.images.forEach(img => {
      const el = document.createElement('img');
      el.src = img.src; el.alt = img.alt;
      el.className = 'w-full h-auto object-cover'; el.style.borderRadius = '1rem';
      el.loading = 'lazy'; el.decoding = 'async';
      imagesEl.appendChild(el);
    });
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeLightbox() {
    lightbox?.classList.remove('active');
    document.body.style.overflow = '';
    if (imagesEl) imagesEl.innerHTML = '';
  }

  document.querySelectorAll('[data-gallery-id]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.galleryId;
      if (id) openGallery(id);
    });
  });
  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

</script>
