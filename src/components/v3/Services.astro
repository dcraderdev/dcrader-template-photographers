---
import type { Package } from '../../data/v1/packages';
interface Props { packages: Package[]; }
const { packages } = Astro.props;
---

<!-- V3: Organic bohemian cards with terracotta accents -->
<section id="services" class="py-24 lg:py-40" style="background:var(--c-bg)" aria-label="Services and pricing">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <div class="text-center mb-16 lg:mb-24 fade-hidden">
      <p class="text-[10px] uppercase tracking-[0.3em] mb-4" style="color:var(--c-accent)">Investment</p>
      <h2 class="italic" style="font-family:var(--f-display);font-size:clamp(2.5rem,5vw,5rem);color:var(--c-text)">Your Adventure</h2>
      <p class="mt-4 text-sm font-light max-w-md mx-auto" style="color:var(--c-text-muted)">
        Every elopement is unique. These are starting points — let's talk about yours.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-6">
      {packages.map((pkg, i) => (
        <div class={`relative p-8 lg:p-10 fade-hidden ${pkg.featured ? 'lg:-mt-6 lg:mb-6' : ''}`}
          style={`background:${pkg.featured ? 'var(--c-bg-alt)' : 'var(--c-bg-accent)'};border-radius:4px;transition-delay:${i*0.1}s`}>

          {pkg.featured && (
            <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 px-4 py-1.5 text-[9px] uppercase tracking-wider"
              style="background:var(--c-accent);color:white;border-radius:9999px">
              Most Loved
            </div>
          )}

          <!-- Terracotta leaf decoration on featured -->
          <div class="mb-6">
            <p class="text-[10px] uppercase tracking-[0.3em] mb-2" style={`color:${pkg.featured ? 'var(--c-accent)' : 'var(--c-text-muted)'}`}>Adventure</p>
            <h3 class="italic text-3xl lg:text-4xl" style={`font-family:var(--f-display);color:${pkg.featured ? 'var(--c-text-inv)' : 'var(--c-text)'}`}>
              {pkg.name}
            </h3>
          </div>

          <p class="text-sm leading-relaxed mb-6 font-light" style={`color:${pkg.featured ? 'rgba(250,246,240,0.65)' : 'var(--c-text-muted)'}`}>
            {pkg.description}
          </p>

          <p class="text-xs uppercase tracking-widest mb-6" style={`color:${pkg.featured ? 'var(--c-accent)' : 'var(--c-accent-dark)'}`}>
            {pkg.hours}
          </p>

          <ul class="space-y-3 mb-8 flex-1" aria-label={`Included in ${pkg.name}`}>
            {pkg.highlights.map(item => (
              <li class="flex items-start gap-3 text-sm font-light"
                style={`color:${pkg.featured ? 'rgba(250,246,240,0.75)' : 'var(--c-text)'}`}>
                <span style={`color:var(--c-accent);flex-shrink:0;margin-top:2px`} aria-hidden="true">✦</span>
                {item}
              </li>
            ))}
          </ul>

          <div class="pt-6" style={`border-top:1px solid ${pkg.featured ? 'rgba(250,246,240,0.15)' : 'var(--c-accent);opacity:0.3'}`}>
            <p class="text-[10px] uppercase tracking-[0.25em] mb-1" style={`color:${pkg.featured ? 'rgba(250,246,240,0.4)' : 'var(--c-text-muted)'}`}>Starting at</p>
            <p class="text-4xl mb-6 italic" style={`font-family:var(--f-display);color:${pkg.featured ? 'var(--c-text-inv)' : 'var(--c-text)'}`}>{pkg.startingAt}</p>
            <a href="#inquire"
              class="block text-center text-xs uppercase tracking-[0.2em] py-3.5 transition-all duration-300"
              style={`background:${pkg.featured ? 'var(--c-accent)' : 'transparent'};color:${pkg.featured ? 'white' : 'var(--c-text)'};border:1px solid ${pkg.featured ? 'transparent' : 'var(--c-accent)'};border-radius:2px`}>
              Let's Talk
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
