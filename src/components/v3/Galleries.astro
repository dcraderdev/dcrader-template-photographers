---
import type { Gallery } from '../../data/v1/galleries';
import ResponsiveImage from '../shared/ResponsiveImage.astro';
interface Props { galleries: Gallery[]; galleriesJson: string; }
const { galleries, galleriesJson } = Astro.props;

// Pre-defined scrapbook layout: overlapping offsets + rotations
const layout = [
  { rot: '-2.5deg',  mt: '0',     ml: '0%',  w: '340px', zIndex: 3, note: 'the one that started it all ✨' },
  { rot: '1.8deg',   mt: '-30px', ml: '42%', w: '300px', zIndex: 4, note: 'golden hour magic 🌅' },
  { rot: '-1.2deg',  mt: '60px',  ml: '68%', w: '280px', zIndex: 2, note: 'fav from this whole year' },
  { rot: '2.2deg',   mt: '320px', ml: '5%',  w: '310px', zIndex: 5, note: 'they were so in love 🌿' },
  { rot: '-0.8deg',  mt: '280px', ml: '38%', w: '290px', zIndex: 3, note: 'chasing golden hour' },
  { rot: '1.5deg',   mt: '310px', ml: '64%', w: '300px', zIndex: 4, note: 'never stop roaming 🌸' },
];
---

<script id="galleries-data" type="application/json" set:html={galleriesJson}></script>

<!-- V3: Scrapbook wall — overlapping polaroids with Caveat annotations -->
<section id="galleries" aria-label="Featured galleries" style="background:var(--c-bg-accent)">

  <!-- Section header with wildflower ornament -->
  <div class="text-center pt-24 lg:pt-32 pb-16 fade-hidden">
    <!-- Wildflower row -->
    <div class="flex items-center justify-center gap-3 mb-6" aria-hidden="true">
      <svg width="28" height="40" viewBox="0 0 28 40" fill="none">
        <path d="M14 38 C14 28, 13 16, 14 4" stroke="var(--c-accent)" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="14" cy="4" r="3.5" fill="var(--c-accent)" opacity="0.7"/>
        <circle cx="9" cy="7" r="2.5" fill="var(--c-accent2)" opacity="0.5"/>
        <circle cx="19" cy="7" r="2.5" fill="var(--c-accent2)" opacity="0.5"/>
      </svg>
      <svg width="20" height="28" viewBox="0 0 20 28" fill="none">
        <path d="M10 26 C10 18, 9 10, 10 2" stroke="var(--c-accent2)" stroke-width="1.2" stroke-linecap="round"/>
        <circle cx="10" cy="2" r="2.5" fill="var(--c-accent2)" opacity="0.6"/>
        <circle cx="6" cy="4.5" r="1.8" fill="var(--c-accent)" opacity="0.4"/>
        <circle cx="14" cy="4.5" r="1.8" fill="var(--c-accent)" opacity="0.4"/>
      </svg>
      <svg width="32" height="48" viewBox="0 0 32 48" fill="none">
        <path d="M16 46 C16 34, 14 18, 16 4" stroke="var(--c-accent)" stroke-width="1.8" stroke-linecap="round"/>
        <circle cx="16" cy="4" r="4" fill="var(--c-accent)" opacity="0.8"/>
        <circle cx="10" cy="7" r="3" fill="var(--c-accent2)" opacity="0.6"/>
        <circle cx="22" cy="7" r="3" fill="var(--c-accent2)" opacity="0.6"/>
        <circle cx="13" cy="1" r="2" fill="var(--c-accent)" opacity="0.5"/>
        <circle cx="19" cy="1" r="2" fill="var(--c-accent)" opacity="0.5"/>
      </svg>
      <svg width="20" height="28" viewBox="0 0 20 28" fill="none">
        <path d="M10 26 C10 18, 9 10, 10 2" stroke="var(--c-accent2)" stroke-width="1.2" stroke-linecap="round"/>
        <circle cx="10" cy="2" r="2.5" fill="var(--c-accent2)" opacity="0.6"/>
        <circle cx="6" cy="4.5" r="1.8" fill="var(--c-accent)" opacity="0.4"/>
        <circle cx="14" cy="4.5" r="1.8" fill="var(--c-accent)" opacity="0.4"/>
      </svg>
      <svg width="28" height="40" viewBox="0 0 28 40" fill="none">
        <path d="M14 38 C14 28, 13 16, 14 4" stroke="var(--c-accent)" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="14" cy="4" r="3.5" fill="var(--c-accent)" opacity="0.7"/>
        <circle cx="9" cy="7" r="2.5" fill="var(--c-accent2)" opacity="0.5"/>
        <circle cx="19" cy="7" r="2.5" fill="var(--c-accent2)" opacity="0.5"/>
      </svg>
    </div>

    <p class="text-[10px] uppercase tracking-[0.3em] mb-3" style="color:var(--c-accent);font-family:var(--f-display)">Our Work</p>
    <h2 class="italic mb-2" style="font-family:var(--f-display);font-size:clamp(2.8rem,6vw,5.5rem);color:var(--c-text);font-weight:300">Wild Moments</h2>
    <!-- Caveat sub-heading -->
    <p class="text-xl lg:text-2xl" style="font-family:var(--f-hand);color:var(--c-accent)">we chase golden hour wherever it leads</p>
  </div>

  <!-- Scrapbook wall — desktop: absolute overlap; mobile: responsive grid -->
  <div class="hidden lg:block relative mx-auto" style="max-width:1100px;height:780px;padding:0 2rem">
    {galleries.map((gallery, i) => {
      const l = layout[i] || layout[0];
      return (
        <button
          class="gallery-card absolute text-left cursor-pointer hover:z-10 transition-all duration-500 group"
          style={`transform:rotate(${l.rot});margin-top:${l.mt};left:${l.ml};width:${l.w};z-index:${l.zIndex};`}
          aria-label={`Open ${gallery.title} gallery`}
          data-gallery-id={gallery.id}
          type="button"
        >
          <!-- Polaroid frame -->
          <div class="bg-white shadow-xl group-hover:shadow-2xl transition-all duration-400 group-hover:scale-105" style="padding:10px 10px 52px 10px">
            <div class="overflow-hidden" style="aspect-ratio:1">
              <ResponsiveImage
                src={gallery.coverImage}
                alt={gallery.coverAlt}
                class="w-full h-full object-cover transition-transform duration-600 group-hover:scale-110"
                loading="lazy"
                decoding="async"
              />
            </div>
            <!-- Polaroid caption in Caveat -->
            <div class="px-2 pt-3 text-center">
              <p style="font-family:var(--f-hand);font-size:0.95rem;color:var(--c-text-muted)">
                {gallery.title}
              </p>
            </div>
          </div>

          <!-- Caveat handwriting annotation (outside polaroid) -->
          <p
            class="absolute -bottom-7 left-0 right-0 text-center opacity-70"
            style="font-family:var(--f-hand);font-size:0.85rem;color:var(--c-accent)"
            aria-hidden="true"
          >
            {l.note}
          </p>

          <!-- Washi tape top (decorative) -->
          <div
            class="absolute -top-2 left-1/2 -translate-x-1/2 w-10 h-4 opacity-60 rounded-sm"
            style="background:var(--c-accent2)"
            aria-hidden="true"
          ></div>
        </button>
      );
    })}
  </div>

  <!-- Mobile: clean grid of polaroids -->
  <div class="lg:hidden grid grid-cols-2 gap-6 px-6 pb-16">
    {galleries.map((gallery, i) => {
      const rots = ['-2deg', '1.5deg', '-1deg', '2deg', '-1.5deg', '1deg'];
      return (
        <button
          class="gallery-card group text-left cursor-pointer transition-transform duration-400 hover:scale-105"
          style={`transform:rotate(${rots[i % 6]})`}
          aria-label={`Open ${gallery.title} gallery`}
          data-gallery-id={gallery.id}
          type="button"
        >
          <div class="bg-white shadow-lg" style="padding:8px 8px 44px 8px">
            <div class="overflow-hidden aspect-square">
              <ResponsiveImage src={gallery.coverImage} alt={gallery.coverAlt}
                class="w-full h-full object-cover" loading="lazy" decoding="async" />
            </div>
            <div class="pt-2 text-center">
              <p style="font-family:var(--f-hand);font-size:0.85rem;color:var(--c-text-muted)">{gallery.title}</p>
            </div>
          </div>
        </button>
      );
    })}
  </div>

  <!-- Call to action below scrapbook -->
  <div class="text-center pb-24 lg:pb-32 fade-hidden" style="transition-delay:0.3s">
    <p class="mb-6 text-2xl" style="font-family:var(--f-hand);color:var(--c-text-muted)">want to see more?</p>
    <a href="#inquire"
      class="inline-block transition-all duration-300 hover:opacity-80"
      style="font-family:var(--f-display);font-size:0.65rem;text-transform:uppercase;letter-spacing:0.3em;border:1px solid var(--c-accent);color:var(--c-accent);padding:0.8rem 2rem">
      Plan Your Adventure
    </a>
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="lightbox-overlay" role="dialog" aria-modal="true" aria-label="Gallery lightbox">
  <div class="w-full max-w-5xl py-8 lg:py-16">
    <button id="lightbox-close" class="fixed top-6 right-6 lg:top-8 lg:right-8 z-10 flex items-center gap-3"
      style="color:white" aria-label="Close gallery" type="button">
      <span style="font-family:var(--f-hand);font-size:1.1rem;color:rgba(253,248,242,0.7)">close ×</span>
    </button>
    <div class="px-6 mb-10">
      <p id="lightbox-subtitle" class="text-[9px] uppercase tracking-[0.3em] mb-3" style="color:var(--c-accent);font-family:var(--f-display)"></p>
      <h3 id="lightbox-title" class="italic leading-none" style="font-family:var(--f-display);font-size:clamp(2.2rem,5vw,4.5rem);color:white;font-weight:300"></h3>
    </div>
    <div id="lightbox-images" class="flex flex-col gap-4 px-6"></div>
  </div>
</div>

<script>
  const galData: { id: string; title: string; subtitle: string; images: { src: string; alt: string }[] }[] =
    JSON.parse((document.getElementById('galleries-data') as HTMLScriptElement)?.text || '[]');

  const lightbox = document.getElementById('lightbox');
  const closeBtn = document.getElementById('lightbox-close');
  const titleEl  = document.getElementById('lightbox-title');
  const subtitleEl = document.getElementById('lightbox-subtitle');
  const imagesEl = document.getElementById('lightbox-images');

  function openGallery(id: string) {
    const g = galData.find(x => x.id === id);
    if (!g || !lightbox || !titleEl || !subtitleEl || !imagesEl) return;
    titleEl.textContent = g.title;
    subtitleEl.textContent = g.subtitle;
    imagesEl.innerHTML = '';
    g.images.forEach(img => {
      const el = document.createElement('img');
      el.src = img.src; el.alt = img.alt;
      el.className = 'w-full h-auto object-cover'; el.loading = 'lazy'; el.decoding = 'async';
      imagesEl.appendChild(el);
    });
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeLightbox() {
    lightbox?.classList.remove('active');
    document.body.style.overflow = '';
    if (imagesEl) imagesEl.innerHTML = '';
  }

  document.querySelectorAll('[data-gallery-id]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.galleryId;
      if (id) openGallery(id);
    });
  });
  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

</script>
