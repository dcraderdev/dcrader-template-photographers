---
interface Props {
  name: string; portraitImage: string; portraitAlt: string;
  aboutParagraph1: string; aboutParagraph2: string;
  philosophyQuote: string; philosophyAuthor: string;
}
const p = Astro.props;
---

<!-- V3: Warm, organic — circle portrait, flowing text, botanical feel -->
<section id="about" class="py-24 lg:py-40" style="background:var(--c-bg-alt)" aria-label={`About ${p.name}`}>
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <!-- Large italic heading centered -->
    <div class="text-center mb-16 lg:mb-24 fade-hidden">
      <p class="text-[10px] uppercase tracking-[0.3em] mb-4" style="color:var(--c-accent)">About</p>
      <h2 class="italic leading-tight" style="font-family:var(--f-display);font-size:clamp(2.5rem,5vw,5rem);color:var(--c-text-inv)">
        The hearts<br />behind the lens
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Portrait in circle with terracotta ring -->
      <div class="flex justify-center lg:justify-end fade-hidden">
        <div class="relative">
          <!-- Outer terracotta ring -->
          <div class="absolute -inset-3 rounded-full" style="border:2px solid var(--c-accent);opacity:0.4" aria-hidden="true"></div>
          <div class="w-64 h-64 lg:w-80 lg:h-80 rounded-full overflow-hidden">
            <img src={p.portraitImage} alt={p.portraitAlt}
              class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </div>
          <!-- Floating terracotta badge -->
          <div class="absolute -bottom-4 -right-4 px-5 py-3" style="background:var(--c-accent)">
            <p class="text-[9px] uppercase tracking-[0.2em]" style="color:var(--c-text-inv)">Since 2016</p>
          </div>
        </div>
      </div>

      <!-- Text column -->
      <div class="fade-hidden" style="transition-delay:0.15s">
        <div class="space-y-6 text-sm lg:text-base leading-relaxed font-light mb-10" style="color:rgba(250,246,240,0.7)">
          <p set:html={p.aboutParagraph1}></p>
          <p set:html={p.aboutParagraph2}></p>
        </div>

        <!-- Hand-feel quote block -->
        <figure class="pl-6" style="border-left:2px solid var(--c-accent)">
          <blockquote class="text-lg lg:text-xl italic leading-relaxed" style="font-family:var(--f-display);color:rgba(250,246,240,0.8)">
            "{p.philosophyQuote}"
          </blockquote>
          <figcaption class="mt-3 text-[9px] uppercase tracking-[0.25em]" style="color:var(--c-accent)">
            — {p.philosophyAuthor}
          </figcaption>
        </figure>
      </div>
    </div>
  </div>
</section>
