---
import ResponsiveImage from '../shared/ResponsiveImage.astro';
interface Props {
  name: string; portraitImage: string; portraitAlt: string;
  aboutParagraph1: string; aboutParagraph2: string;
  philosophyQuote: string; philosophyAuthor: string;
}
const p = Astro.props;
---

<!-- V3: Bohemian — circular portrait, Caveat handwriting annotations, wildflowers -->
<section id="about" class="py-24 lg:py-40 relative overflow-hidden" style="background:var(--c-bg-alt)" aria-label={`About ${p.name}`}>

  <!-- Background wildflower ornament (subtle) -->
  <div class="absolute top-8 right-8 opacity-10 pointer-events-none" aria-hidden="true">
    <svg width="200" height="300" viewBox="0 0 200 300" fill="none">
      <path d="M100 298 C100 220, 96 140, 100 20" stroke="var(--c-accent)" stroke-width="3" stroke-linecap="round"/>
      <path d="M100 200 C68 178, 40 165, 20 148" stroke="var(--c-accent)" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M100 160 C135 138, 162 126, 178 110" stroke="var(--c-accent)" stroke-width="2.5" stroke-linecap="round"/>
      <circle cx="100" cy="20" r="14" fill="var(--c-accent)"/>
      <circle cx="80" cy="28" r="9" fill="var(--c-accent2)"/>
      <circle cx="120" cy="28" r="9" fill="var(--c-accent2)"/>
      <circle cx="20" cy="148" r="12" fill="var(--c-accent)"/>
      <circle cx="178" cy="110" r="12" fill="var(--c-accent)"/>
    </svg>
  </div>

  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <!-- Caveat intro line -->
    <p class="text-center text-2xl lg:text-3xl mb-16 fade-hidden" style="font-family:var(--f-hand);color:rgba(253,248,242,0.55)">
      two cameras, one obsession, zero regrets
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-28 items-center">

      <!-- Portrait: circle with terracotta ring + Caveat badge -->
      <div class="flex justify-center lg:justify-end fade-hidden">
        <div class="relative">
          <!-- Outer ring -->
          <div class="absolute -inset-4 rounded-full" style="border:1px solid rgba(196,103,58,0.35)" aria-hidden="true"></div>
          <!-- Second ring -->
          <div class="absolute -inset-8 rounded-full" style="border:1px solid rgba(212,168,67,0.2)" aria-hidden="true"></div>

          <div class="w-64 h-64 lg:w-80 lg:h-80 rounded-full overflow-hidden">
            <ResponsiveImage src={p.portraitImage} alt={p.portraitAlt}
              class="w-full h-full object-cover" loading="lazy" decoding="async" />
          </div>

          <!-- Caveat floating badge -->
          <div class="absolute -bottom-6 -right-6 px-5 py-4 rotate-3" style="background:var(--c-accent)">
            <p style="font-family:var(--f-hand);font-size:1rem;color:var(--c-text-inv)">Since 2016 ✨</p>
          </div>

          <!-- Small wildflower cluster (top left) -->
          <div class="absolute -top-4 -left-4 opacity-60" aria-hidden="true">
            <svg width="40" height="55" viewBox="0 0 40 55" fill="none">
              <path d="M20 54 C20 38, 18 20, 20 4" stroke="var(--c-accent2)" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="20" cy="4" r="4" fill="var(--c-accent)" opacity="0.8"/>
              <circle cx="14" cy="7" r="2.8" fill="var(--c-accent2)" opacity="0.6"/>
              <circle cx="26" cy="7" r="2.8" fill="var(--c-accent2)" opacity="0.6"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Text column -->
      <div class="fade-hidden" style="transition-delay:0.15s">
        <p class="text-[9px] uppercase tracking-[0.35em] mb-5" style="color:var(--c-accent);font-family:var(--f-display)">About</p>
        <h2 class="italic leading-tight mb-8 fade-hidden" style="font-family:var(--f-display);font-size:clamp(2.2rem,4vw,3.8rem);color:var(--c-text-inv);font-weight:300;transition-delay:0.22s">
          The hearts<br />behind the lens
        </h2>

        <div class="space-y-5 leading-relaxed font-light text-sm lg:text-base mb-10" style="color:rgba(253,248,242,0.65);font-family:var(--f-body)">
          <p set:html={p.aboutParagraph1}></p>
          <p set:html={p.aboutParagraph2}></p>
        </div>

        <!-- Quote block with Caveat attribution -->
        <figure class="pl-6 py-2" style="border-left:1.5px solid var(--c-accent)">
          <blockquote class="italic leading-relaxed" style="font-family:var(--f-display);font-size:clamp(1.05rem,2vw,1.3rem);color:rgba(253,248,242,0.75)">
            "{p.philosophyQuote}"
          </blockquote>
          <figcaption class="mt-4" style="font-family:var(--f-hand);font-size:1rem;color:var(--c-accent)">
            — {p.philosophyAuthor}
          </figcaption>
        </figure>
      </div>
    </div>
  </div>
</section>

