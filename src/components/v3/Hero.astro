---
interface Props {
  name: string;
  subtagline: string;
  tagline: string;
  heroImage: string;
  heroImageAlt: string;
}
const { name, subtagline, tagline, heroImage, heroImageAlt } = Astro.props;
---

<!-- V3: Full-bleed golden-hour photo, Cormorant + Caveat, wildflower SVG ornaments -->
<section id="hero" class="relative h-screen min-h-[680px] overflow-hidden" aria-label="Hero">

  <!-- Photo fill -->
  <div class="absolute inset-0">
    <img src={heroImage} alt={heroImageAlt}
      class="w-full h-full object-cover ken-burns"
      loading="eager" fetchpriority="high" decoding="async" />
    <!-- Warm golden overlay -->
    <div class="absolute inset-0" style="background:linear-gradient(to bottom, rgba(46,32,22,0.3) 0%, rgba(46,32,22,0.1) 40%, rgba(46,32,22,0.72) 100%)" aria-hidden="true"></div>
  </div>

  <!-- Wildflower SVG top-left ornament -->
  <div class="absolute top-16 left-6 lg:left-12 opacity-50 pointer-events-none" aria-hidden="true">
    <svg width="80" height="120" viewBox="0 0 80 120" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Stem -->
      <path d="M40 118 C40 90, 38 60, 40 20" stroke="rgba(212,168,67,0.7)" stroke-width="1.5" stroke-linecap="round"/>
      <!-- Left branch -->
      <path d="M40 80 C30 72, 18 68, 12 62" stroke="rgba(212,168,67,0.7)" stroke-width="1.2" stroke-linecap="round"/>
      <!-- Right branch -->
      <path d="M40 65 C52 57, 62 54, 68 48" stroke="rgba(212,168,67,0.7)" stroke-width="1.2" stroke-linecap="round"/>
      <!-- Top bloom -->
      <circle cx="40" cy="20" r="5" fill="rgba(196,103,58,0.6)"/>
      <circle cx="32" cy="16" r="3" fill="rgba(212,168,67,0.5)"/>
      <circle cx="48" cy="16" r="3" fill="rgba(212,168,67,0.5)"/>
      <circle cx="36" cy="10" r="2.5" fill="rgba(196,103,58,0.4)"/>
      <circle cx="44" cy="10" r="2.5" fill="rgba(196,103,58,0.4)"/>
      <!-- Left bloom -->
      <circle cx="12" cy="62" r="4" fill="rgba(196,103,58,0.5)"/>
      <circle cx="6" cy="60" r="2.5" fill="rgba(212,168,67,0.4)"/>
      <!-- Right bloom -->
      <circle cx="68" cy="48" r="4" fill="rgba(196,103,58,0.5)"/>
      <circle cx="74" cy="46" r="2.5" fill="rgba(212,168,67,0.4)"/>
    </svg>
  </div>

  <!-- Wildflower SVG top-right ornament (mirrored) -->
  <div class="absolute top-16 right-6 lg:right-12 opacity-50 pointer-events-none" style="transform:scaleX(-1)" aria-hidden="true">
    <svg width="80" height="120" viewBox="0 0 80 120" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M40 118 C40 90, 38 60, 40 20" stroke="rgba(212,168,67,0.7)" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M40 80 C30 72, 18 68, 12 62" stroke="rgba(212,168,67,0.7)" stroke-width="1.2" stroke-linecap="round"/>
      <path d="M40 65 C52 57, 62 54, 68 48" stroke="rgba(212,168,67,0.7)" stroke-width="1.2" stroke-linecap="round"/>
      <circle cx="40" cy="20" r="5" fill="rgba(196,103,58,0.6)"/>
      <circle cx="32" cy="16" r="3" fill="rgba(212,168,67,0.5)"/>
      <circle cx="48" cy="16" r="3" fill="rgba(212,168,67,0.5)"/>
      <circle cx="36" cy="10" r="2.5" fill="rgba(196,103,58,0.4)"/>
      <circle cx="44" cy="10" r="2.5" fill="rgba(196,103,58,0.4)"/>
      <circle cx="12" cy="62" r="4" fill="rgba(196,103,58,0.5)"/>
      <circle cx="6" cy="60" r="2.5" fill="rgba(212,168,67,0.4)"/>
      <circle cx="68" cy="48" r="4" fill="rgba(196,103,58,0.5)"/>
      <circle cx="74" cy="46" r="2.5" fill="rgba(212,168,67,0.4)"/>
    </svg>
  </div>

  <!-- Centered content -->
  <div class="relative h-full flex flex-col items-center justify-end pb-20 lg:pb-32 text-center px-6">

    <!-- Caveat handwriting label -->
    <p
      class="mb-3 fade-hidden"
      style="font-family:var(--f-hand);font-size:1.35rem;color:rgba(253,248,242,0.65);transition-delay:0.2s"
    >
      {subtagline}
    </p>

    <!-- Name in Cormorant italic -->
    <h1
      class="fade-hidden"
      style="font-family:var(--f-display);font-size:clamp(3.5rem,9vw,8rem);font-style:italic;color:var(--c-text-inv);line-height:1.0;font-weight:300;transition-delay:0.38s"
    >
      {name}
    </h1>

    <!-- Terracotta divider with tiny wildflower -->
    <div class="flex items-center gap-3 my-6 fade-hidden" style="transition-delay:0.5s" aria-hidden="true">
      <div class="w-12 h-px" style="background:var(--c-accent);opacity:0.6"></div>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
        <circle cx="6" cy="6" r="2.5" fill="var(--c-accent)"/>
        <circle cx="6" cy="1.5" r="1.5" fill="rgba(196,103,58,0.5)"/>
        <circle cx="6" cy="10.5" r="1.5" fill="rgba(196,103,58,0.5)"/>
        <circle cx="1.5" cy="6" r="1.5" fill="rgba(196,103,58,0.5)"/>
        <circle cx="10.5" cy="6" r="1.5" fill="rgba(196,103,58,0.5)"/>
      </svg>
      <div class="w-12 h-px" style="background:var(--c-accent);opacity:0.6"></div>
    </div>

    <!-- Tagline in Caveat -->
    <p
      class="mb-10 fade-hidden"
      style="font-family:var(--f-hand);font-size:clamp(1.4rem,3vw,2rem);color:rgba(253,248,242,0.8);transition-delay:0.62s"
    >
      {tagline}
    </p>

    <a
      href="#galleries"
      class="inline-block transition-all duration-400 fade-hidden hover:opacity-80"
      style="font-family:var(--f-display);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.3em;border:1px solid rgba(253,248,242,0.5);color:var(--c-text-inv);padding:0.9rem 2rem;transition-delay:0.78s"
    >
      See Our Work
    </a>
  </div>

  <!-- Scroll line -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 fade-hidden" style="transition-delay:1s" aria-hidden="true">
    <div class="w-px h-12 animate-pulse mx-auto" style="background:rgba(253,248,242,0.35)"></div>
  </div>
</section>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('fade-visible'); });
  }, { threshold: 0.05 });
  document.querySelectorAll('.fade-hidden').forEach(el => obs.observe(el));
</script>
