---
interface Props {
  name: string;
  subtagline: string;
  tagline: string;
  heroImage: string;
  heroImageAlt: string;
}
const { name, subtagline, tagline, heroImage, heroImageAlt } = Astro.props;
---

<!-- V3: Full-bleed warm photo, centered text in botanical frame -->
<section id="hero" class="relative h-screen min-h-[640px] overflow-hidden" aria-label="Hero">

  <!-- Warm photo fill -->
  <div class="absolute inset-0">
    <img src={heroImage} alt={heroImageAlt}
      class="w-full h-full object-cover ken-burns"
      loading="eager" fetchpriority="high" decoding="async" />
    <!-- Warm amber overlay for film feel -->
    <div class="absolute inset-0" style="background:linear-gradient(to bottom,rgba(44,36,22,0.25),rgba(44,36,22,0.65))" aria-hidden="true"></div>
  </div>

  <!-- Centered content -->
  <div class="relative h-full flex flex-col items-center justify-center text-center px-6">

    <!-- Botanical frame (CSS border decoration) -->
    <div class="relative px-10 py-10 fade-hidden" style="transition-delay:0.2s">

      <!-- Corner decorations -->
      <span class="absolute top-0 left-0 w-10 h-10" style="border-top:1px solid rgba(250,246,240,0.5);border-left:1px solid rgba(250,246,240,0.5)" aria-hidden="true"></span>
      <span class="absolute top-0 right-0 w-10 h-10" style="border-top:1px solid rgba(250,246,240,0.5);border-right:1px solid rgba(250,246,240,0.5)" aria-hidden="true"></span>
      <span class="absolute bottom-0 left-0 w-10 h-10" style="border-bottom:1px solid rgba(250,246,240,0.5);border-left:1px solid rgba(250,246,240,0.5)" aria-hidden="true"></span>
      <span class="absolute bottom-0 right-0 w-10 h-10" style="border-bottom:1px solid rgba(250,246,240,0.5);border-right:1px solid rgba(250,246,240,0.5)" aria-hidden="true"></span>

      <p class="text-[10px] uppercase tracking-[0.4em] mb-5 font-light" style="color:rgba(250,246,240,0.7)">{subtagline}</p>

      <h1 class="mb-4 fade-hidden" style="font-family:var(--f-display);font-size:clamp(2.5rem,7vw,6rem);font-style:italic;color:var(--c-bg);line-height:1.1;transition-delay:0.35s">
        {name}
      </h1>

      <!-- Terracotta divider -->
      <div class="w-10 h-px mx-auto mb-5 fade-hidden" style="background:var(--c-accent);transition-delay:0.45s" aria-hidden="true"></div>

      <p class="font-light text-lg lg:text-xl mb-8 fade-hidden" style="color:rgba(250,246,240,0.85);font-style:italic;transition-delay:0.55s">
        {tagline}
      </p>

      <a href="#galleries"
        class="inline-block text-xs uppercase tracking-[0.25em] px-8 py-3.5 transition-all duration-400 fade-hidden"
        style="border:1px solid rgba(250,246,240,0.6);color:var(--c-bg);transition-delay:0.7s">
        See Our Work
      </a>
    </div>
  </div>

  <!-- Scroll line -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 fade-hidden" style="transition-delay:0.9s" aria-hidden="true">
    <div class="w-px h-12 animate-pulse" style="background:rgba(250,246,240,0.4)"></div>
  </div>
</section>
