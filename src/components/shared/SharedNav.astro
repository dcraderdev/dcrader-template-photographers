---
/* Universal nav — reads CSS vars set by each theme page */
interface Props {
  name: string;
  variant: 'v1' | 'v2' | 'v3' | 'v4' | 'v5';
  /** When on a sub-page, prefix in-page anchors with the home path so they navigate back. */
  homeHref?: string;
  /** Optional extra link rendered before "Inquire" — used by sub-pages. */
  extraLink?: { href: string; label: string };
}
const { name, variant, homeHref, extraLink } = Astro.props;
const base = homeHref ?? '';
const links = [
  { href: `${base}#galleries`, label: 'Work' },
  { href: `${base}#about`,     label: 'About' },
  { href: `${base}#services`,  label: 'Services' },
  { href: `${base}#testimonials`, label: 'Praise' },
];
if (extraLink) links.push(extraLink);
const inquireHref = `${base}#inquire`;
const logoHref = homeHref ?? '#hero';
---

<nav id="main-nav" class={`fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 lg:px-16 pt-10 pb-5 lg:py-6 transition-all duration-500 nav-${variant}`}
  aria-label="Main navigation">

  <a href={logoHref} class="nav-logo transition-colors duration-300" aria-label={`${name} — home`}>
    {name}
  </a>

  <ul class="hidden lg:flex items-center gap-10 text-xs uppercase tracking-widest font-light nav-links">
    {links.map(l => <li><a href={l.href} class="nav-link transition-colors duration-300">{l.label}</a></li>)}
    <li>
      <a href={inquireHref} class="nav-cta text-xs uppercase tracking-[0.2em] px-5 py-2 transition-all duration-300">
        Inquire
      </a>
    </li>
  </ul>

  <button id="mobile-menu-btn" class="lg:hidden flex flex-col gap-1.5 p-2" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
    <span class="block w-6 h-px nav-bar transition-all duration-300" id="bar1"></span>
    <span class="block w-6 h-px nav-bar transition-all duration-300" id="bar2"></span>
    <span class="block w-4 h-px nav-bar transition-all duration-300 self-end" id="bar3"></span>
  </button>
</nav>

<div id="mobile-menu" class="fixed inset-0 z-40 flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300"
  style="background:var(--c-bg-alt)" aria-hidden="true">
  <ul class="flex flex-col items-center gap-8 text-2xl" style="font-family:var(--f-display);color:var(--c-text-inv)">
    {[...links, { href: inquireHref, label:'Inquire' }].map(l => (
      <li><a href={l.href} class="mobile-link transition-colors hover:opacity-70">{l.label}</a></li>
    ))}
  </ul>
</div>

<style>
  /* Scrolled state: solid dark bar; cream text reads regardless of variant */
  #main-nav.is-scrolled {
    background: var(--c-bg-alt);
    box-shadow: 0 1px 20px rgba(0,0,0,0.18);
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
  #main-nav.is-scrolled .nav-logo,
  #main-nav.is-scrolled .nav-link { color: var(--c-text-inv); text-shadow: none; }
  #main-nav.is-scrolled .nav-bar { background: var(--c-text-inv); }

  /* ───── V1 — Cinematic Quiet ─────
     Hero opens with cream margin around a framed photo; nav sits on cream.
     At top: dark text on cream margin (readable). After scroll: cream on dark. */
  .nav-v1 .nav-logo { font-family: var(--f-display); font-size: 1.2rem; color: var(--c-text); letter-spacing: 0.05em; }
  .nav-v1 .nav-link { color: var(--c-text); }
  .nav-v1 .nav-link:hover { color: var(--c-accent-dark); }
  .nav-v1 .nav-cta { border: 1px solid var(--c-text); color: var(--c-text); }
  .nav-v1 .nav-cta:hover { background: var(--c-text); color: var(--c-text-inv); }
  .nav-v1 .nav-bar { background: var(--c-text); }
  #main-nav.nav-v1.is-scrolled .nav-cta { border-color: rgba(255,255,255,0.6); color: var(--c-text-inv); }

  /* ───── V2 — Bold Editorial ─────
     Hero is dark photo with heavy black gradient overlay; cream text needed at top. */
  .nav-v2 .nav-logo { font-family: var(--f-display); font-size: 1.4rem; color: var(--c-text-inv); letter-spacing: 0.1em; text-shadow: 0 1px 12px rgba(0,0,0,0.4); }
  .nav-v2 .nav-link { color: var(--c-text-inv); text-shadow: 0 1px 8px rgba(0,0,0,0.4); }
  .nav-v2 .nav-link:hover { color: var(--c-accent); }
  .nav-v2 .nav-cta { background: var(--c-accent); color: white; }
  .nav-v2 .nav-cta:hover { background: var(--c-accent-dark); }
  .nav-v2 .nav-bar { background: var(--c-text-inv); }

  /* ───── V3 — Bohemian Warm ─────
     Hero is bright golden-hour image. Cream text needs shadow for legibility on bright areas. */
  .nav-v3 .nav-logo { font-family: var(--f-display); font-size: 1.1rem; font-style: italic; color: var(--c-text-inv); letter-spacing: 0.03em; text-shadow: 0 1px 14px rgba(46,32,22,0.55); }
  .nav-v3 .nav-link { color: var(--c-text-inv); text-shadow: 0 1px 10px rgba(46,32,22,0.5); }
  .nav-v3 .nav-link:hover { color: var(--c-accent); }
  .nav-v3 .nav-cta { border: 1px solid rgba(255,255,255,0.7); color: var(--c-text-inv); text-shadow: 0 1px 10px rgba(46,32,22,0.5); }
  .nav-v3 .nav-cta:hover { background: rgba(255,255,255,0.15); }
  .nav-v3 .nav-bar { background: var(--c-text-inv); }

  /* ───── V4 — Modern Minimal ─────
     Hero is white left split + photo right. Nav sits over white left half → black text. */
  .nav-v4 .nav-logo { font-family: var(--f-display); font-size: 1rem; color: var(--c-text); letter-spacing: 0.2em; text-transform: uppercase; }
  .nav-v4 .nav-link { color: rgba(15,15,15,0.7); }
  .nav-v4 .nav-link:hover { color: var(--c-text); }
  .nav-v4 .nav-cta { border: 1px solid rgba(15,15,15,0.4); color: var(--c-text); }
  .nav-v4 .nav-cta:hover { background: var(--c-text); color: white; }
  .nav-v4 .nav-bar { background: var(--c-text); }
  /* V4's --c-bg-alt is platinum (#f5f5f5), so scrolled state stays dark-on-light. */
  #main-nav.nav-v4.is-scrolled { background: rgba(255,255,255,0.92) !important; backdrop-filter: blur(8px); box-shadow: 0 1px 1px rgba(0,0,0,0.05); }
  #main-nav.nav-v4.is-scrolled .nav-logo,
  #main-nav.nav-v4.is-scrolled .nav-link { color: var(--c-text); }
  #main-nav.nav-v4.is-scrolled .nav-link { color: rgba(15,15,15,0.7); }
  #main-nav.nav-v4.is-scrolled .nav-link:hover { color: var(--c-text); }
  #main-nav.nav-v4.is-scrolled .nav-cta { border-color: rgba(15,15,15,0.4); color: var(--c-text); }
  #main-nav.nav-v4.is-scrolled .nav-bar { background: var(--c-text); }

  /* ───── V5 — Vibrant Joyful ─────
     Hero opens with cream margin; bento yellow/coral tiles below. Black wordmark on cream is fine. */
  .nav-v5 .nav-logo { font-family: var(--f-display); font-size: 1.1rem; font-weight: 700; color: var(--c-text); letter-spacing: -0.01em; }
  .nav-v5 .nav-link { color: var(--c-text); }
  .nav-v5 .nav-link:hover { color: var(--c-accent-dark); }
  .nav-v5 .nav-cta { background: var(--c-accent); color: var(--c-text); font-weight: 600; border-radius: 9999px; }
  .nav-v5 .nav-cta:hover { background: var(--c-accent-dark); }
  .nav-v5 .nav-bar { background: var(--c-text); }
</style>

<script>
  const nav = document.getElementById('main-nav');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let open = false;

  window.addEventListener('scroll', () => {
    if (!nav) return;
    if (window.scrollY > 80) {
      nav.classList.add('is-scrolled');
    } else {
      nav.classList.remove('is-scrolled');
    }
  });

  btn?.addEventListener('click', () => {
    open = !open;
    if (menu) {
      menu.classList.toggle('opacity-0', !open);
      menu.classList.toggle('pointer-events-none', !open);
      menu.setAttribute('aria-hidden', String(!open));
    }
    btn.setAttribute('aria-expanded', String(open));
    if (bar1 && bar2 && bar3) {
      if (open) {
        bar1.style.transform = 'translateY(8px) rotate(45deg)';
        bar2.style.opacity = '0';
        bar3.style.transform = 'translateY(-8px) rotate(-45deg)';
        bar3.style.width = '24px';
      } else {
        bar1.style.transform = '';
        bar2.style.opacity = '1';
        bar3.style.transform = '';
        bar3.style.width = '';
      }
    }
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      open = false;
      menu?.classList.add('opacity-0', 'pointer-events-none');
      menu?.setAttribute('aria-hidden', 'true');
      btn?.setAttribute('aria-expanded', 'false');
      if (bar1 && bar2 && bar3) {
        bar1.style.transform = ''; bar2.style.opacity = '1'; bar3.style.transform = ''; bar3.style.width = '';
      }
    });
  });
</script>
