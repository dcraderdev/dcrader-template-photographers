---
interface Props {
  name: string;
  email: string;
  location: string;
  instagramUrl: string;
  instagram: string;
  heading?: string;
  subheading?: string;
  submitLabel?: string;
}
const {
  name, email, location, instagramUrl, instagram,
  heading = 'Tell me about your day',
  subheading = 'I read every message personally. Fill out what you can — even if you\'re early in the planning. I\'ll get back to you within 48 hours.',
  submitLabel = 'Send My Inquiry',
} = Astro.props;
---

<section id="inquire" class="py-24 lg:py-40" style="background:var(--c-bg-alt)" aria-label="Inquiry form">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">

      <!-- Left: warm copy -->
      <div class="fade-hidden">
        <p class="text-[10px] uppercase tracking-[0.3em] mb-6" style="color:var(--c-accent)">Let's Connect</p>
        <h2 class="text-4xl lg:text-6xl mb-8 leading-tight" style="font-family:var(--f-display);color:var(--c-text-inv)">
          {heading}
        </h2>
        <p class="text-sm lg:text-base leading-relaxed mb-10 font-light" style="color:rgba(255,255,255,0.6)">{subheading}</p>
        <div class="space-y-5">
          {[email, location].map(item => (
            <div class="flex items-center gap-4">
              <span class="w-px h-8" style="background:var(--c-accent)" aria-hidden="true"></span>
              <p class="text-sm font-light" style="color:rgba(255,255,255,0.6)">{item}</p>
            </div>
          ))}
          <div class="flex items-center gap-4">
            <span class="w-px h-8" style="background:var(--c-accent)" aria-hidden="true"></span>
            <a href={instagramUrl} target="_blank" rel="noopener noreferrer"
              class="text-sm font-light transition-colors" style="color:rgba(255,255,255,0.6)"
              aria-label={`Visit ${instagram} on Instagram (opens in new tab)`}>{instagram}</a>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <form id="inquiry-form" class="space-y-6 fade-hidden" style="transition-delay:0.15s" novalidate aria-label="Wedding inquiry form">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {[
            { id:'your-name', name:'your_name', label:'Your name', placeholder:'Emma', autocomplete:'given-name', required: true },
            { id:'partner-name', name:'partner_name', label:"Partner's name", placeholder:'James', autocomplete:'off', required: true },
          ].map(f => (
            <div>
              <label for={f.id} class="block text-[10px] uppercase tracking-[0.25em] mb-2" style="color:rgba(255,255,255,0.5)">
                {f.label} {f.required && <span style="color:var(--c-accent)" aria-label="required">*</span>}
              </label>
              <input type="text" id={f.id} name={f.name} required={f.required} autocomplete={f.autocomplete}
                placeholder={f.placeholder}
                class="w-full bg-transparent pb-3 text-sm font-light focus:outline-none transition-colors"
                style="border-bottom:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.9)" />
            </div>
          ))}
        </div>

        <div>
          <label for="inquiry-email" class="block text-[10px] uppercase tracking-[0.25em] mb-2" style="color:rgba(255,255,255,0.5)">
            Email <span style="color:var(--c-accent)" aria-label="required">*</span>
          </label>
          <input type="email" id="inquiry-email" name="email" required autocomplete="email"
            placeholder="hello@you.com"
            class="w-full bg-transparent pb-3 text-sm font-light focus:outline-none transition-colors"
            style="border-bottom:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.9)" />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <label for="wedding-date" class="block text-[10px] uppercase tracking-[0.25em] mb-2" style="color:rgba(255,255,255,0.5)">Wedding date</label>
            <input type="date" id="wedding-date" name="wedding_date"
              class="w-full bg-transparent pb-3 text-sm font-light focus:outline-none transition-colors [color-scheme:dark]"
              style="border-bottom:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.9)" />
          </div>
          <div>
            <label for="venue" class="block text-[10px] uppercase tracking-[0.25em] mb-2" style="color:rgba(255,255,255,0.5)">Venue / location</label>
            <input type="text" id="venue" name="venue" placeholder="Big Sur, CA"
              class="w-full bg-transparent pb-3 text-sm font-light focus:outline-none transition-colors"
              style="border-bottom:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.9)" />
          </div>
        </div>

        <div>
          <label for="vibe" class="block text-[10px] uppercase tracking-[0.25em] mb-2" style="color:rgba(255,255,255,0.5)">How would you describe your wedding's vibe?</label>
          <input type="text" id="vibe" name="vibe" placeholder="Intimate garden party, moody + romantic..."
            class="w-full bg-transparent pb-3 text-sm font-light focus:outline-none transition-colors"
            style="border-bottom:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.9)" />
        </div>

        <fieldset>
          <legend class="block text-[10px] uppercase tracking-[0.25em] mb-4" style="color:rgba(255,255,255,0.5)">Budget range</legend>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {['Under $3k','$3k–$5k','$5k–$8k','$8k+'].map(range => (
              <label class="cursor-pointer">
                <input type="radio" name="budget" value={range} class="sr-only peer" />
                <span class="block text-center text-[10px] uppercase tracking-wide py-2.5 transition-all cursor-pointer"
                  style="border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.5)">
                  {range}
                </span>
              </label>
            ))}
          </div>
        </fieldset>

        <div>
          <label for="message" class="block text-[10px] uppercase tracking-[0.25em] mb-2" style="color:rgba(255,255,255,0.5)">Anything you'd like me to know?</label>
          <textarea id="message" name="message" rows="4" placeholder="Tell me your story..."
            class="w-full bg-transparent pb-3 text-sm font-light focus:outline-none transition-colors resize-none"
            style="border-bottom:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.9)"></textarea>
        </div>

        <div class="pt-4">
          <button type="submit"
            class="inquiry-submit w-full sm:w-auto text-xs uppercase tracking-[0.25em] px-10 py-4 transition-all duration-300"
            style="background:var(--c-accent);color:var(--c-text-inv)">
            {submitLabel}
          </button>
        </div>
        <p id="inquiry-success" class="hidden text-sm font-light pt-2" style="color:var(--c-accent)">
          Your message is on its way. I'll be in touch within 48 hours.
        </p>
      </form>
    </div>
  </div>

  <style>
    /* a11y: visible focus on form inputs (focus:outline-none was removing the only indicator) */
    #inquiry-form input,
    #inquiry-form textarea {
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }
    #inquiry-form input:hover,
    #inquiry-form textarea:hover {
      border-bottom-color: rgba(255,255,255,0.45) !important;
    }
    #inquiry-form input:focus-visible,
    #inquiry-form textarea:focus-visible {
      border-bottom-color: var(--c-accent) !important;
      box-shadow: 0 1px 0 0 var(--c-accent);
    }
    /* Radio peer-checked + hover/focus for budget buttons */
    #inquiry-form input[type="radio"]:checked + span {
      border-color: var(--c-accent) !important;
      color: var(--c-text-inv) !important;
      background: rgba(255,255,255,0.06);
    }
    #inquiry-form label:hover span {
      border-color: rgba(255,255,255,0.45) !important;
      color: rgba(255,255,255,0.85) !important;
    }
    #inquiry-form input[type="radio"]:focus-visible + span {
      outline: 2px solid var(--c-accent);
      outline-offset: 2px;
    }
    /* Submit button */
    .inquiry-submit {
      filter: brightness(1);
    }
    .inquiry-submit:hover {
      filter: brightness(1.08);
      transform: translateY(-1px);
    }
    .inquiry-submit:focus-visible {
      outline: 2px solid var(--c-accent);
      outline-offset: 3px;
    }
  </style>
</section>

<script>
  const form = document.getElementById('inquiry-form') as HTMLFormElement | null;
  const success = document.getElementById('inquiry-success');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.style.opacity = '0.5';
    form.style.pointerEvents = 'none';
    success?.classList.remove('hidden');
  });
</script>
