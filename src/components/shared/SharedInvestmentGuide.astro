---
interface Props {
  headline: string;
  subline: string;
  ctaLabel: string;
}
const { headline, subline, ctaLabel } = Astro.props;
---

<section id="investment-guide" class="py-24 lg:py-32" style="background:var(--c-bg-accent)" aria-label="Download investment guide">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">
    <div class="max-w-2xl mx-auto text-center fade-hidden">
      <span class="block w-12 h-px mx-auto mb-10" style="background:var(--c-accent)" aria-hidden="true"></span>
      <h2 class="text-3xl lg:text-5xl mb-6 leading-snug" style="font-family:var(--f-display);color:var(--c-text)">{headline}</h2>
      <p class="text-sm lg:text-base leading-relaxed mb-12 font-light" style="color:var(--c-text-muted)">{subline}</p>
      <form id="investment-guide-form" class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto" novalidate aria-label="Get the guide">
        <label for="guide-email" class="sr-only">Your email address</label>
        <input type="email" id="guide-email" name="email" placeholder="your@email.com" required autocomplete="email"
          class="flex-1 px-5 py-3.5 text-sm focus:outline-none transition-colors"
          style="background:white;border:1px solid var(--c-border);color:var(--c-text)" />
        <button type="submit"
          class="text-xs uppercase tracking-[0.2em] px-7 py-3.5 whitespace-nowrap transition-colors duration-300"
          style="background:var(--c-text);color:var(--c-text-inv)">
          {ctaLabel}
        </button>
      </form>
      <p id="guide-success" class="hidden mt-6 text-sm font-light" style="color:var(--c-accent-dark)">
        Check your inbox — your guide is on its way.
      </p>
      <p class="mt-5 text-[10px] tracking-wide" style="color:var(--c-text-muted)">No spam. Unsubscribe anytime.</p>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('investment-guide-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('guide-success');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.style.display = 'none';
    successMsg?.classList.remove('hidden');
  });
</script>
