---
import { photographer } from '../data/photographer';
---

<section id="hero" class="relative h-screen min-h-[600px] overflow-hidden" aria-label="Hero">
  <!-- Full-bleed cinematic image with Ken Burns -->
  <div class="absolute inset-0">
    <img
      src={photographer.heroImage}
      alt={photographer.heroImageAlt}
      class="w-full h-full object-cover ken-burns"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <!-- Layered gradient: bottom-heavy dark overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/10 to-black/70"></div>
  </div>

  <!-- Content -->
  <div class="relative h-full flex flex-col items-center justify-end pb-24 lg:pb-32 text-center px-6">
    <!-- Wordmark -->
    <p
      class="text-[10px] lg:text-xs uppercase tracking-[0.35em] text-[var(--color-rose-light)] font-light mb-5 fade-hidden"
      style="transition-delay: 0.2s"
    >
      {photographer.subtagline}
    </p>

    <h1
      class="font-serif text-[3rem] leading-[1.05] lg:text-[7rem] text-[var(--color-cream)] mb-6 fade-hidden"
      style="transition-delay: 0.4s"
    >
      {photographer.name}
    </h1>

    <span class="divider-rose mb-7 fade-hidden" style="transition-delay: 0.55s" aria-hidden="true"></span>

    <p
      class="font-serif italic text-xl lg:text-3xl text-[var(--color-cream)] tracking-wide mb-12 fade-hidden"
      style="transition-delay: 0.65s"
    >
      {photographer.tagline}
    </p>

    <a
      href="#galleries"
      class="inline-block text-xs uppercase tracking-[0.25em] text-[var(--color-cream)] border border-[var(--color-cream)]/60 px-8 py-3.5 hover:bg-[var(--color-cream)] hover:text-[var(--color-warm-black)] hover:border-[var(--color-cream)] transition-all duration-400 fade-hidden"
      style="transition-delay: 0.8s"
    >
      View Galleries
    </a>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 fade-hidden"
    style="transition-delay: 1.1s"
    aria-hidden="true"
  >
    <div class="w-px h-12 bg-[var(--color-cream)]/40 animate-pulse"></div>
  </div>
</section>
