---
import { photographer } from '../data/v1/photographer';
import ResponsiveImage from './shared/ResponsiveImage.astro';
---

<section id="hero" class="relative h-screen min-h-[600px] overflow-hidden" aria-label="Hero">
  <!-- Full-bleed cinematic image with Ken Burns -->
  <div class="absolute inset-0">
    <ResponsiveImage
      src={photographer.heroImage}
      alt={photographer.heroImageAlt}
      class="w-full h-full object-cover ken-burns"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <!-- Layered gradient: bottom-heavy dark overlay -->
    <div class="absolute inset-0" style="background:linear-gradient(to bottom, rgba(28,24,20,0.15) 0%, rgba(28,24,20,0.05) 40%, rgba(28,24,20,0.75) 100%)"></div>
  </div>

  <!-- Content -->
  <div class="relative h-full flex flex-col items-center justify-end pb-20 lg:pb-28 text-center px-6">

    <!-- Eyebrow -->
    <p
      class="text-[9px] lg:text-[10px] uppercase tracking-[0.45em] font-light mb-6 fade-hidden"
      style="color:rgba(247,243,238,0.65); font-family:var(--f-body); transition-delay:0.2s"
    >
      {photographer.subtagline}
    </p>

    <!-- Name in Fraunces -->
    <h1
      class="leading-none mb-5 fade-hidden"
      style="font-family:var(--f-display); font-size:clamp(3.5rem,9vw,8rem); color:var(--c-text-inv); font-weight:400; letter-spacing:-0.01em; transition-delay:0.4s"
    >
      {photographer.name}
    </h1>

    <!-- Hand-stamped SVG signature -->
    <div class="mb-8 fade-hidden" style="transition-delay:0.6s" aria-hidden="true">
      <svg viewBox="0 0 220 60" width="160" height="45" fill="none" xmlns="http://www.w3.org/2000/svg" class="signature-svg opacity-70">
        <!-- Stylized "Emma" script signature -->
        <path
          d="M12 42 C18 20, 28 14, 36 18 C42 22, 40 36, 38 42 C36 48, 34 50, 32 48 C30 46, 32 36, 40 30 C50 22, 60 20, 68 26 C74 30, 72 40, 70 44 C68 50, 66 52, 64 50 C62 48, 64 36, 72 28 C82 18, 96 16, 104 22 C112 28, 110 42, 108 46 C104 54, 100 52, 98 46 C96 40, 102 30, 116 32 C128 34, 140 42, 148 48 C156 54, 162 58, 170 52 C178 46, 180 32, 178 24 C176 16, 172 14, 168 18 C164 22, 164 36, 170 44 C178 54, 190 56, 200 50 C210 44, 212 32, 208 24"
          stroke="var(--c-accent)"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          pathLength="1"
          class="signature-path"
        />
      </svg>
    </div>

    <!-- Tagline in Fraunces italic -->
    <p
      class="mb-12 fade-hidden"
      style="font-family:var(--f-display); font-style:italic; font-size:clamp(1.1rem,2.5vw,1.6rem); color:rgba(247,243,238,0.82); letter-spacing:0.02em; transition-delay:0.75s"
    >
      {photographer.tagline}
    </p>

    <!-- CTA -->
    <a
      href="#galleries"
      class="inline-block text-[10px] uppercase tracking-[0.3em] px-8 py-3.5 transition-all duration-500 hover:bg-[var(--c-text-inv)] fade-hidden"
      style="border:1px solid rgba(247,243,238,0.5); color:var(--c-text-inv); font-family:var(--f-body); transition-delay:0.95s"
    >
      Enter the Gallery
    </a>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center fade-hidden"
    style="transition-delay:1.2s"
    aria-hidden="true"
  >
    <div class="w-px h-14 animate-pulse" style="background:rgba(247,243,238,0.3)"></div>
  </div>
</section>

<style>
  a:hover { color: var(--c-bg-alt); }

  /* Trigger signature draw after page load */
  @keyframes drawSig {
    from { stroke-dashoffset: 1; }
    to   { stroke-dashoffset: 0; }
  }
  .signature-path {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
  }
  .signature-path.drawing {
    animation: drawSig 2.2s ease-out 1.4s forwards;
  }
</style>

<script>
  const path = document.querySelector('.signature-path');
  if (path) {
    setTimeout(() => path.classList.add('drawing'), 800);
  }

</script>
