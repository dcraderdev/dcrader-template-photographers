---
import { packages } from '../data/v1/packages';
---

<section id="services" class="py-28 lg:py-44" style="background:var(--c-bg)" aria-label="Services and pricing">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <!-- Header -->
    <div class="text-center mb-20 lg:mb-28 fade-hidden">
      <p class="text-[9px] uppercase tracking-[0.4em] mb-5" style="color:var(--c-text-muted);font-family:var(--f-body)">Investment</p>
      <h2 class="mb-5" style="font-family:var(--f-display);font-size:clamp(2.5rem,5vw,4.5rem);color:var(--c-text);font-weight:400">Collections</h2>
      <p class="font-light max-w-md mx-auto text-sm leading-relaxed" style="color:var(--c-text-muted);font-family:var(--f-body)">
        Every wedding is different. These are starting points — we'll talk through what makes sense for your day.
      </p>
    </div>

    <!-- Package cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 lg:gap-6">
      {packages.map((pkg, i) => (
        <div
          class={`relative flex flex-col p-9 lg:p-10 fade-hidden`}
          style={`
            transition-delay:${i * 0.12}s;
            background:${pkg.featured ? 'var(--c-bg-alt)' : 'white'};
            border:1px solid ${pkg.featured ? 'transparent' : 'rgba(201,169,154,0.2)'};
          `}
        >
          {pkg.featured && (
            <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2">
              <span class="text-[8px] uppercase tracking-[0.3em] px-5 py-1.5" style="background:var(--c-accent);color:var(--c-text-inv);font-family:var(--f-body)">
                Most Popular
              </span>
            </div>
          )}

          <p class="text-[9px] uppercase tracking-[0.35em] mb-3" style={`color:${pkg.featured ? 'var(--c-accent)' : 'var(--c-text-muted)'};font-family:var(--f-body)`}>
            Collection
          </p>
          <h3 class="mb-2" style={`font-family:var(--f-display);font-size:2rem;color:${pkg.featured ? 'var(--c-text-inv)' : 'var(--c-text)'};font-weight:400`}>
            {pkg.name}
          </h3>
          <p class="text-sm leading-relaxed mb-7 font-light" style={`color:${pkg.featured ? 'rgba(247,243,238,0.6)' : 'var(--c-text-muted)'};font-family:var(--f-body)`}>
            {pkg.description}
          </p>

          <p class="text-[9px] uppercase tracking-[0.3em] mb-6" style={`color:${pkg.featured ? 'rgba(201,169,154,0.8)' : 'var(--c-accent-dark)'};font-family:var(--f-body)`}>
            {pkg.hours}
          </p>

          <ul class="space-y-3 mb-10 flex-1" aria-label={`What's included in ${pkg.name}`}>
            {pkg.highlights.map(item => (
              <li class="flex items-start gap-3 text-sm font-light" style={`color:${pkg.featured ? 'rgba(247,243,238,0.75)' : 'var(--c-text)'};font-family:var(--f-body)`}>
                <span class="mt-0.5 flex-shrink-0" style="color:var(--c-accent)" aria-hidden="true">—</span>
                {item}
              </li>
            ))}
          </ul>

          <div class="pt-8" style={`border-top:1px solid ${pkg.featured ? 'rgba(247,243,238,0.1)' : 'rgba(201,169,154,0.2)'}`}>
            <p class="text-[9px] uppercase tracking-[0.25em] mb-1.5" style={`color:${pkg.featured ? 'rgba(247,243,238,0.4)' : 'var(--c-text-muted)'};font-family:var(--f-body)`}>
              Starting at
            </p>
            <p class="mb-8" style={`font-family:var(--f-display);font-size:2.5rem;color:${pkg.featured ? 'var(--c-text-inv)' : 'var(--c-text)'};font-weight:400`}>
              {pkg.startingAt}
            </p>
            <a
              href="#inquire"
              class="block text-center text-[9px] uppercase tracking-[0.25em] py-3.5 transition-all duration-400 hover:opacity-80"
              style={`font-family:var(--f-body);background:${pkg.featured ? 'var(--c-accent)' : 'transparent'};color:${pkg.featured ? 'var(--c-text-inv)' : 'var(--c-text)'};border:1px solid ${pkg.featured ? 'transparent' : 'var(--c-text)'}`}
            >
              Inquire
            </a>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-[9px] font-light mt-12 fade-hidden" style="transition-delay:0.4s;color:var(--c-text-muted);font-family:var(--f-body)">
      Travel included within 100 miles of California. Custom quotes for destination weddings.
    </p>
  </div>
</section>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('fade-visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-hidden').forEach(el => obs.observe(el));
</script>
