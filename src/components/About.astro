---
import { photographer } from '../data/v1/photographer';
---

<section id="about" class="py-28 lg:py-44" style="background:var(--c-bg-alt)" aria-label="About Emma Hayes">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-28 items-center">

      <!-- Portrait with soft offset border -->
      <div class="relative fade-hidden">
        <div class="relative aspect-[3/4] overflow-hidden max-w-sm mx-auto lg:mx-0">
          <img
            src={photographer.portraitImage}
            alt={photographer.portraitAlt}
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
        <!-- Dusty rose offset border -->
        <div
          class="absolute -bottom-5 -right-5 w-4/5 h-4/5 -z-10"
          style="border:1px solid rgba(201,169,154,0.25)"
          aria-hidden="true"
        ></div>
      </div>

      <!-- Text -->
      <div class="fade-hidden" style="transition-delay:0.18s">
        <p class="text-[9px] uppercase tracking-[0.4em] mb-6" style="color:var(--c-accent);font-family:var(--f-body)">About</p>
        <h2 class="leading-tight mb-10 fade-hidden" style="font-family:var(--f-display);font-size:clamp(2.4rem,4.5vw,4rem);color:var(--c-text-inv);font-weight:400;transition-delay:0.25s">
          The woman<br />behind the lens
        </h2>

        <div class="space-y-5 leading-relaxed text-base font-light mb-12" style="color:rgba(247,243,238,0.65);font-family:var(--f-body)">
          <p set:html={photographer.aboutParagraph1}></p>
          <p set:html={photographer.aboutParagraph2}></p>
        </div>

        <!-- Philosophy quote in Fraunces italic -->
        <figure class="pl-7" style="border-left:1px solid var(--c-accent)">
          <blockquote class="italic leading-relaxed" style="font-family:var(--f-display);font-size:clamp(1.1rem,2vw,1.35rem);color:rgba(247,243,238,0.75)">
            "{photographer.philosophyQuote}"
          </blockquote>
          <figcaption class="mt-4 text-[9px] uppercase tracking-[0.3em]" style="color:var(--c-accent);font-family:var(--f-body)">
            — {photographer.philosophyAuthor}
          </figcaption>
        </figure>
      </div>
    </div>
  </div>
</section>

