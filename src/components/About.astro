---
import { photographer } from '../data/photographer';
---

<section id="about" class="py-24 lg:py-40 bg-[var(--color-warm-black)]" aria-label="About Emma Hayes">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Portrait -->
      <div class="relative fade-hidden">
        <div class="relative aspect-[3/4] overflow-hidden">
          <img
            src={photographer.portraitImage}
            alt={photographer.portraitAlt}
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
        <!-- Decorative offset border -->
        <div
          class="absolute -bottom-4 -right-4 w-3/4 h-3/4 border border-[var(--color-rose)]/30 -z-10"
          aria-hidden="true"
        ></div>
        <!-- Floating stat -->
        <div class="absolute -bottom-8 -left-4 lg:-left-8 bg-[var(--color-rose)] px-7 py-5">
          <p class="font-serif text-4xl text-[var(--color-cream)]">10+</p>
          <p class="text-[9px] uppercase tracking-[0.25em] text-[var(--color-cream)]/80 mt-1">Years of stories told</p>
        </div>
      </div>

      <!-- Text -->
      <div class="lg:pl-8 fade-hidden" style="transition-delay: 0.15s">
        <p class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-rose)] mb-6">About</p>
        <h2 class="font-serif text-4xl lg:text-6xl text-[var(--color-cream)] mb-10 leading-tight">
          The woman<br />behind the lens
        </h2>

        <div class="space-y-6 text-[var(--color-cream)]/70 leading-relaxed font-light text-base lg:text-lg">
          <p set:html={photographer.aboutParagraph1}></p>
          <p set:html={photographer.aboutParagraph2}></p>
        </div>

        <!-- Philosophy quote -->
        <figure class="mt-12 border-l-2 border-[var(--color-rose)] pl-8">
          <blockquote class="font-serif italic text-xl lg:text-2xl text-[var(--color-cream)]/80 leading-relaxed">
            "{photographer.philosophyQuote}"
          </blockquote>
          <figcaption class="mt-4 text-[9px] uppercase tracking-[0.25em] text-[var(--color-muted)]">
            — {photographer.philosophyAuthor}
          </figcaption>
        </figure>
      </div>
    </div>
  </div>
</section>
