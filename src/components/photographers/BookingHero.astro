---
import ResponsiveImage from '../shared/ResponsiveImage.astro';
interface Props {
  name: string;
  subtagline: string;
  tagline: string;
  heroImage: string;
  heroImageAlt: string;
}
const { name, subtagline, tagline, heroImage, heroImageAlt } = Astro.props;

const today = new Date();
const monthName = today.toLocaleString('en-US', { month: 'long' });
const year = today.getFullYear();

// Build a tiny calendar grid for the current month — purely decorative, real flow lives in the form
const firstDay = new Date(year, today.getMonth(), 1).getDay();
const daysInMonth = new Date(year, today.getMonth() + 1, 0).getDate();
const cells = [
  ...Array(firstDay).fill(null),
  ...Array.from({ length: daysInMonth }, (_, i) => i + 1),
];
// Mark a few "available" days as visual texture
const availableDays = new Set([5, 12, 19, 20, 26]);

const sessionTypes = [
  { id: 'wedding',    label: 'Wedding day',       hours: '8–12 hrs', from: '$3,500' },
  { id: 'elopement',  label: 'Elopement',         hours: '2–4 hrs',  from: '$1,800' },
  { id: 'portrait',   label: 'Portrait session',  hours: '90 min',   from: '$650' },
  { id: 'engagement', label: 'Engagement',        hours: '2 hrs',    from: '$850' },
];

const weekday = ['S','M','T','W','T','F','S'];
---

<!-- V5 — Booking Calendar Hero: a working date-picker + session-type selector is the hero -->
<section id="hero" class="relative w-full min-h-screen" aria-label="Hero" style="background:var(--c-bg-mid)">

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-0 min-h-screen">

    <!-- Left: photo + intro -->
    <div class="lg:col-span-5 relative overflow-hidden min-h-[420px] lg:min-h-0">
      <ResponsiveImage
        src={heroImage}
        alt={heroImageAlt}
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0" aria-hidden="true"
        style="background:linear-gradient(180deg, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.55) 100%)"></div>
      <div class="absolute inset-0 flex flex-col justify-end p-8 lg:p-12">
        <p class="text-[10px] uppercase tracking-[0.45em]" style="color:rgba(255,255,255,0.8); font-family:var(--f-body)">
          {subtagline}
        </p>
        <h1 class="mt-4" style="font-family:var(--f-display); color:white; font-weight:700; font-size:clamp(2.25rem,4.5vw,4rem); letter-spacing:-0.015em; line-height:1">
          {name}
        </h1>
        <p class="mt-4 max-w-md" style="color:rgba(255,255,255,0.85); font-family:var(--f-body)">
          {tagline}
        </p>
      </div>
    </div>

    <!-- Right: booking widget -->
    <div class="lg:col-span-7 px-6 lg:px-14 py-12 lg:py-20 flex flex-col justify-center" style="background:var(--c-bg)">
      <div class="max-w-2xl">
        <p class="text-[10px] uppercase tracking-[0.4em]" style="color:var(--c-accent); font-family:var(--f-body)">
          Check date availability
        </p>
        <h2 class="mt-3" style="font-family:var(--f-display); color:var(--c-text); font-weight:700; font-size:clamp(1.75rem,3vw,2.5rem); line-height:1.1">
          When are you celebrating?
        </h2>
        <p class="mt-3 text-sm" style="color:var(--c-text-muted)">
          Pick a date and a session type. We'll confirm availability within 24 hours.
        </p>

        <form action="#inquire" method="get" class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-8 items-start">

          <!-- Calendar -->
          <div>
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs uppercase tracking-[0.3em]" style="color:var(--c-text-muted)">{monthName} {year}</span>
              <span class="text-[10px]" style="color:var(--c-text-muted)">● available</span>
            </div>
            <div class="grid grid-cols-7 gap-1 text-center text-[10px]" style="color:var(--c-text-muted)" aria-hidden="true">
              {weekday.map((d) => <div class="py-1">{d}</div>)}
            </div>
            <div class="grid grid-cols-7 gap-1 mt-1" role="grid" aria-label={`${monthName} ${year} availability`}>
              {cells.map((d) => (
                d === null ? (
                  <div></div>
                ) : (
                  <label class={`relative aspect-square flex items-center justify-center text-sm cursor-pointer rounded-sm transition-colors ${availableDays.has(d) ? 'available-day' : 'opacity-40 cursor-not-allowed'}`}
                    style={`border:1px solid var(--c-border); font-family:var(--f-body); color:var(--c-text)`}>
                    {availableDays.has(d) && (
                      <input type="radio" name="date" value={`${year}-${String(today.getMonth()+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`} class="sr-only peer" />
                    )}
                    <span class="peer-checked:font-bold">{d}</span>
                    {availableDays.has(d) && (
                      <span class="absolute bottom-1 w-1 h-1 rounded-full" style="background:var(--c-accent)" aria-hidden="true"></span>
                    )}
                  </label>
                )
              ))}
            </div>
          </div>

          <!-- Session type selector -->
          <div>
            <span class="block text-xs uppercase tracking-[0.3em] mb-3" style="color:var(--c-text-muted)">Session type</span>
            <div class="space-y-2">
              {sessionTypes.map((s, i) => (
                <label class="flex items-center gap-3 p-3 cursor-pointer transition-colors session-option"
                  style="border:1px solid var(--c-border); border-radius:var(--radius)">
                  <input type="radio" name="session" value={s.id} class="accent-current" checked={i === 0} />
                  <div class="flex-1 flex justify-between items-baseline">
                    <span style="font-family:var(--f-body); color:var(--c-text); font-weight:500">{s.label}</span>
                    <span class="text-xs" style="color:var(--c-text-muted)">{s.hours} · from {s.from}</span>
                  </div>
                </label>
              ))}
            </div>

            <button type="submit" class="mt-6 w-full py-4 text-[11px] uppercase tracking-[0.35em] transition-opacity hover:opacity-90"
              style="background:var(--c-accent); color:white; font-family:var(--f-body)">
              Continue inquiry →
            </button>
            <p class="mt-3 text-xs text-center" style="color:var(--c-text-muted)">
              No deposit required to check availability.
            </p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .available-day:hover { background: var(--c-accent-light); }
  .session-option:hover { background: var(--c-bg-mid); }
</style>
