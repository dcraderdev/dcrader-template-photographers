---
import ResponsiveImage from '../shared/ResponsiveImage.astro';
interface Props {
  name: string;
  subtagline: string;
  tagline: string;
  heroImage: string;
  heroImageAlt: string;
}
const { name, subtagline, tagline, heroImage, heroImageAlt } = Astro.props;
---

<!-- V1 — Cinematic Quiet hero: single full-bleed image, framed in deep cream margin,
     with a thin film-strip border and exceptionally sparse text. -->
<section id="hero" class="relative w-full" aria-label="Hero" style="background:var(--c-bg)">
  <div class="px-4 sm:px-8 lg:px-16 pt-28 lg:pt-32 pb-12 lg:pb-16">

    <!-- Film-strip border frame -->
    <div class="relative overflow-hidden" style="border:1px solid var(--c-border)">
      <div class="relative w-full" style="aspect-ratio: 16/10; min-height: 480px;">
        <ResponsiveImage
          src={heroImage}
          alt={heroImageAlt}
          class="w-full h-full object-cover"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
        <!-- Subtle vignette for film mood -->
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
          style="background:radial-gradient(ellipse at center, transparent 55%, rgba(28,24,20,0.45) 100%)"></div>
      </div>
    </div>

    <!-- Sparse caption row beneath, like a darkroom contact sheet annotation -->
    <div class="mt-10 lg:mt-14 flex flex-col lg:flex-row lg:items-end justify-between gap-8">
      <div>
        <p class="text-[10px] uppercase tracking-[0.5em]" style="color:var(--c-text-muted); font-family:var(--f-body)">
          Frame 01 — {subtagline}
        </p>
        <h1 class="mt-4" style="font-family:var(--f-display); color:var(--c-text); font-weight:400; font-size:clamp(2.5rem,5vw,4.5rem); letter-spacing:-0.01em; line-height:1.05">
          {name}
        </h1>
      </div>
      <p class="max-w-sm italic" style="font-family:var(--f-display); font-size:clamp(1rem,1.4vw,1.25rem); color:var(--c-text-muted)">
        {tagline}
      </p>
    </div>

    <!-- Hairline divider and minimal CTA -->
    <div class="mt-10 flex items-center gap-6">
      <span class="h-px flex-1" style="background:var(--c-border)" aria-hidden="true"></span>
      <a href="#galleries" class="text-[10px] uppercase tracking-[0.4em] hover:opacity-70 transition-opacity" style="color:var(--c-text); font-family:var(--f-body)">
        Enter the gallery
      </a>
    </div>
  </div>
</section>
