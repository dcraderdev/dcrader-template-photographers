---
import ResponsiveImage from '../shared/ResponsiveImage.astro';
interface Props {
  name: string;
  subtagline: string;
  tagline: string;
  heroImage: string;
  heroImageAlt: string;
}
const { name, subtagline, tagline, heroImage, heroImageAlt } = Astro.props;

// 6-image editorial mosaic — the hero IS the portfolio
const tiles = [
  { src: heroImage, alt: heroImageAlt, span: 'lg:col-span-3 lg:row-span-2' },
  { src: '/images/1519225421980-715cb0215aed-800.webp', alt: 'Editorial bridal portrait, side light', span: 'lg:col-span-2 lg:row-span-1' },
  { src: '/images/1606800052052-a08af7148866-800.webp', alt: 'Couple at twilight, city skyline behind', span: 'lg:col-span-2 lg:row-span-1' },
  { src: '/images/1525772764200-be829a350797-800.webp', alt: 'Candlelit reception in a grand hall', span: 'lg:col-span-2 lg:row-span-1' },
  { src: '/images/1606216794074-735e91aa2c92-800.webp', alt: 'Sleek city couple portrait at dusk', span: 'lg:col-span-2 lg:row-span-1' },
  { src: '/images/1583939003579-730e3918a45a-800.webp', alt: 'Joyful petal toss at the recessional', span: 'lg:col-span-3 lg:row-span-1' },
];
---

<!-- V2 — Gallery Grid Hero: a mosaic IS the hero. Editorial type sits on top. -->
<section id="hero" class="relative w-full min-h-screen" aria-label="Hero" style="background:var(--c-bg-accent)">

  <!-- Mosaic -->
  <div class="grid grid-cols-2 lg:grid-cols-7 lg:grid-rows-3 gap-1 lg:gap-1.5 h-screen min-h-[640px]">
    {tiles.map((t, i) => (
      <div class={`relative overflow-hidden ${t.span}`}>
        <ResponsiveImage
          src={t.src}
          alt={t.alt}
          class="w-full h-full object-cover transition-transform duration-[1200ms] hover:scale-105"
          loading={i === 0 ? 'eager' : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'auto'}
          decoding="async"
        />
      </div>
    ))}
  </div>

  <!-- Type overlay center -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none px-6">
    <div class="text-center max-w-3xl px-8 py-10 lg:px-14 lg:py-12 pointer-events-auto" style="background:rgba(13,13,13,0.78); backdrop-filter:blur(6px)">
      <p class="text-[10px] uppercase tracking-[0.5em]" style="color:var(--c-accent); font-family:var(--f-body)">
        Issue No. 07 — {subtagline}
      </p>
      <div class="mt-5 h-px w-12 mx-auto" style="background:var(--c-accent)" aria-hidden="true"></div>
      <h1 class="mt-6 leading-[0.95]" style="font-family:var(--f-display); color:var(--c-text-inv); font-weight:900; font-size:clamp(2.75rem,6.5vw,5.5rem); letter-spacing:-0.025em">
        {name}
      </h1>
      <p class="mt-6" style="font-family:var(--f-display); font-style:italic; font-size:clamp(1rem,1.6vw,1.4rem); color:rgba(248,248,248,0.75)">
        {tagline}
      </p>
      <a href="#galleries" class="inline-block mt-9 px-9 py-3.5 text-[10px] uppercase tracking-[0.3em]"
        style="background:var(--c-accent); color:white; font-family:var(--f-body)">
        Open the portfolio
      </a>
    </div>
  </div>
</section>
