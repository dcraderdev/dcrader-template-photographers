---
import ResponsiveImage from '../shared/ResponsiveImage.astro';
import type { Testimonial } from '../../data/v4/testimonials';

interface Props {
  name: string;
  subtagline: string;
  tagline: string;
  heroImage: string;
  heroImageAlt: string;
  testimonials: Testimonial[];
}
const { name, subtagline, tagline, heroImage, heroImageAlt, testimonials } = Astro.props;
const featured = testimonials.slice(0, 3);
const supporting = testimonials.slice(0, 4);
---

<!-- V4 — Testimonial Hero: large client quotes scroll across screen. Social proof first. -->
<section id="hero" class="relative w-full min-h-screen" aria-label="Hero" style="background:var(--c-bg)">

  <!-- Top bar -->
  <div class="px-6 lg:px-12 pt-28 pb-6 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
    <div>
      <p class="text-[10px] uppercase tracking-[0.45em]" style="color:var(--c-text-muted); font-family:var(--f-body)">
        {subtagline} · Client Letters
      </p>
      <h1 class="mt-3" style="font-family:var(--f-display); color:var(--c-text); font-weight:500; font-size:clamp(2rem,4.5vw,3.75rem); letter-spacing:-0.02em; line-height:1.02">
        Read what couples write to {name.split(' ')[0]} after the day.
      </h1>
    </div>
    <p class="max-w-sm" style="font-family:var(--f-serif, var(--f-body)); color:var(--c-text-muted)">
      {tagline}
    </p>
  </div>

  <!-- Hero quote, large -->
  <div class="px-6 lg:px-12 pb-8">
    <figure class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
      <blockquote class="lg:col-span-8" style="font-family:var(--f-serif, var(--f-display)); color:var(--c-text); font-size:clamp(1.5rem,2.8vw,2.5rem); line-height:1.25; letter-spacing:-0.01em">
        <span aria-hidden="true" style="color:var(--c-accent); font-size:1.3em; line-height:0">“</span>
        {featured[0]?.quote}
      </blockquote>
      <div class="lg:col-span-4">
        <div class="relative overflow-hidden" style="aspect-ratio: 4/5">
          <ResponsiveImage
            src={featured[0]?.image.replace('-400.webp', '-800.webp') ?? heroImage}
            alt={featured[0]?.imageAlt ?? heroImageAlt}
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
        <figcaption class="mt-3 text-xs uppercase tracking-[0.3em]" style="color:var(--c-text-muted); font-family:var(--f-body)">
          — {featured[0]?.name}, {featured[0]?.weddingInfo}
        </figcaption>
      </div>
    </figure>
  </div>

  <!-- Marquee strip of more testimonials -->
  <div class="border-y" style="border-color:var(--c-border)">
    <div class="overflow-hidden">
      <div class="flex gap-12 py-6 testimonial-marquee">
        {[...supporting, ...supporting].map((t) => (
          <div class="shrink-0 flex items-center gap-4 px-6" style="min-width:540px">
            <span class="text-2xl" style="color:var(--c-accent); font-family:var(--f-display)" aria-hidden="true">★ ★ ★ ★ ★</span>
            <p class="text-sm" style="color:var(--c-text); font-family:var(--f-serif, var(--f-body))">
              <span class="italic">“{t.quote.slice(0, 110).trim()}…”</span>
              <span class="ml-2 text-xs uppercase tracking-[0.25em]" style="color:var(--c-text-muted)">— {t.name}</span>
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Hero CTA + small ref hero image -->
  <div class="px-6 lg:px-12 py-10 lg:py-14 flex flex-col lg:flex-row gap-8 items-start lg:items-end justify-between">
    <div class="max-w-xl">
      <p class="text-xs uppercase tracking-[0.4em]" style="color:var(--c-text-muted)">
        Booking 2026 · By referral and inquiry
      </p>
      <p class="mt-4 text-lg" style="color:var(--c-text); font-family:var(--f-serif, var(--f-body))">
        Every couple shown here was once an unread email. Send yours.
      </p>
      <a href="#inquire" class="inline-block mt-6 px-8 py-3 text-[10px] uppercase tracking-[0.35em]"
        style="background:var(--c-text); color:var(--c-bg); font-family:var(--f-body)">
        Begin an enquiry
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes scrollMarquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .testimonial-marquee {
    animation: scrollMarquee 45s linear infinite;
    width: max-content;
  }
  .testimonial-marquee:hover { animation-play-state: paused; }
  @media (prefers-reduced-motion: reduce) {
    .testimonial-marquee { animation: none; }
  }
</style>
