---
import type { Gallery } from '../../data/v1/galleries';
import ResponsiveImage from '../shared/ResponsiveImage.astro';
interface Props { galleries: Gallery[]; galleriesJson: string; }
const { galleries, galleriesJson } = Astro.props;
---

<script id="galleries-data" type="application/json" set:html={galleriesJson}></script>

<!-- V2: Scroll-snap chapter sections — each gallery is a full-viewport editorial spread -->
<section id="galleries" aria-label="Featured galleries">

  <!-- Section header -->
  <div class="py-16 lg:py-20 fade-hidden" style="background:var(--c-bg)">
    <div class="max-w-screen-xl mx-auto px-6 lg:px-16">
      <div class="flex items-end justify-between">
        <div>
          <p class="text-[9px] uppercase tracking-[0.5em] mb-4" style="color:var(--c-accent);font-family:var(--f-body)">— Selected Work</p>
          <h2 class="leading-none" style="font-family:var(--f-display);font-size:clamp(4rem,10vw,10rem);color:var(--c-text);font-weight:900;letter-spacing:-0.03em">
            WORK
          </h2>
        </div>
        <p class="hidden lg:block text-sm font-light pb-4 max-w-xs text-right" style="color:var(--c-text-muted);font-family:var(--f-body)">
          Every wedding treated as a fashion editorial — precise, bold, unmistakable.
        </p>
      </div>
      <div class="w-full h-px mt-6" style="background:var(--c-accent)" aria-hidden="true"></div>
    </div>
  </div>

  <!-- Scroll-snap chapters container -->
  <div class="chapters-wrapper" style="height:100vh;overflow-y:scroll;scroll-snap-type:y mandatory;" role="region" aria-label="Gallery chapters">
    {galleries.map((gallery, i) => (
      <div
        class="chapter relative overflow-hidden fade-hidden"
        style="height:100vh;scroll-snap-align:start;transition-delay:{i*0.05}s"
        data-gallery-id={gallery.id}
      >
        <!-- Full-bleed image -->
        <ResponsiveImage
          src={gallery.coverImage}
          alt={gallery.coverAlt}
          class="w-full h-full object-cover"
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
        />

        <!-- Heavy gradient overlay: left for text, subtle everywhere else -->
        <div class="absolute inset-0" style="background:linear-gradient(to right, rgba(13,13,13,0.88) 0%, rgba(13,13,13,0.55) 40%, rgba(13,13,13,0.12) 100%)" aria-hidden="true"></div>

        <!-- Chapter number (top right) -->
        <div class="absolute top-8 right-8 lg:top-10 lg:right-12" aria-hidden="true">
          <span style="font-family:var(--f-display);font-size:5rem;font-weight:900;color:rgba(248,248,248,0.06);line-height:1;letter-spacing:-0.05em">
            {String(i + 1).padStart(2, '0')}
          </span>
        </div>

        <!-- Editorial content: left panel -->
        <div class="absolute inset-y-0 left-0 flex flex-col justify-between px-8 lg:px-16 py-12 lg:py-16 max-w-lg">

          <!-- Top: index -->
          <div class="flex items-center gap-4">
            <span class="text-[8px] uppercase tracking-[0.5em] font-light" style="color:rgba(248,248,248,0.3);font-family:var(--f-body)">
              {String(i + 1).padStart(2,'0')} / {String(galleries.length).padStart(2,'0')}
            </span>
            <span class="w-5 h-px" style="background:var(--c-accent)" aria-hidden="true"></span>
          </div>

          <!-- Middle: editorial caption -->
          <div>
            <p class="text-[8px] uppercase tracking-[0.5em] mb-5" style="color:var(--c-accent);font-family:var(--f-body)">{gallery.subtitle}</p>
            <h3 class="leading-none mb-8" style="font-family:var(--f-display);font-size:clamp(2.5rem,6vw,5.5rem);color:white;font-weight:900;letter-spacing:-0.03em">
              {gallery.title}
            </h3>
            <!-- Large editorial caption line -->
            <div class="w-full h-px mb-8" style="background:rgba(200,16,46,0.5)" aria-hidden="true"></div>

            <button
              class="gallery-open-btn flex items-center gap-4 group transition-all duration-300"
              data-gallery-id={gallery.id}
              type="button"
              aria-label={`Open ${gallery.title} gallery`}
            >
              <span class="text-[9px] uppercase tracking-[0.4em] transition-colors" style="color:rgba(248,248,248,0.55);font-family:var(--f-body)">
                Open gallery
              </span>
              <span class="w-6 h-px transition-all duration-400 group-hover:w-12" style="background:var(--c-accent)" aria-hidden="true"></span>
            </button>
          </div>

          <!-- Bottom: scroll cue -->
          <div class="flex items-center gap-3" aria-hidden="true">
            <span class="text-[8px] uppercase tracking-[0.4em] font-light" style="color:rgba(248,248,248,0.2);font-family:var(--f-body)">
              {i < galleries.length - 1 ? 'Scroll' : 'End'}
            </span>
            {i < galleries.length - 1 && (
              <div class="w-px h-8 animate-pulse" style="background:rgba(248,248,248,0.15)"></div>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="lightbox-overlay" role="dialog" aria-modal="true" aria-label="Gallery lightbox">
  <div class="w-full max-w-5xl py-8 lg:py-16">
    <button id="lightbox-close" class="fixed top-6 right-6 lg:top-8 lg:right-8 z-10 flex items-center gap-3"
      style="color:white" aria-label="Close gallery" type="button">
      <span class="text-[9px] uppercase tracking-widest font-light" style="font-family:var(--f-body)">Close</span>
      <span class="text-2xl leading-none" aria-hidden="true">×</span>
    </button>
    <div class="px-6 mb-10">
      <p id="lightbox-subtitle" class="text-[8px] uppercase tracking-[0.4em] mb-3" style="color:var(--c-accent);font-family:var(--f-body)"></p>
      <h3 id="lightbox-title" class="font-black leading-none" style="font-family:var(--f-display);font-size:clamp(2.5rem,6vw,5rem);color:white;letter-spacing:-0.03em"></h3>
    </div>
    <div id="lightbox-images" class="flex flex-col gap-4 px-6"></div>
  </div>
</div>

<script>
  const galData: { id: string; title: string; subtitle: string; images: { src: string; alt: string }[] }[] =
    JSON.parse((document.getElementById('galleries-data') as HTMLScriptElement)?.text || '[]');

  const lightbox = document.getElementById('lightbox');
  const closeBtn = document.getElementById('lightbox-close');
  const titleEl  = document.getElementById('lightbox-title');
  const subtitleEl = document.getElementById('lightbox-subtitle');
  const imagesEl = document.getElementById('lightbox-images');

  function openGallery(id: string) {
    const g = galData.find(x => x.id === id);
    if (!g || !lightbox || !titleEl || !subtitleEl || !imagesEl) return;
    titleEl.textContent = g.title;
    subtitleEl.textContent = g.subtitle;
    imagesEl.innerHTML = '';
    g.images.forEach(img => {
      const el = document.createElement('img');
      el.src = img.src; el.alt = img.alt;
      el.className = 'w-full h-auto object-cover';
      el.loading = 'lazy'; el.decoding = 'async';
      imagesEl.appendChild(el);
    });
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeLightbox() {
    lightbox?.classList.remove('active');
    document.body.style.overflow = '';
    if (imagesEl) imagesEl.innerHTML = '';
  }

  document.querySelectorAll('.gallery-open-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.galleryId;
      if (id) openGallery(id);
    });
  });

  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

</script>
