---
import type { Gallery } from '../../data/v1/galleries';
interface Props { galleries: Gallery[]; galleriesJson: string; }
const { galleries, galleriesJson } = Astro.props;
---

<script id="galleries-data" type="application/json" set:html={galleriesJson}></script>

<!-- V2: Editorial — full-width asymmetric grid, B&W hover treatment -->
<section id="galleries" class="py-20 lg:py-32" style="background:var(--c-bg)" aria-label="Featured galleries">

  <!-- Header: stark, flush-left -->
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16 mb-12 lg:mb-16 fade-hidden">
    <div class="flex items-end justify-between">
      <div>
        <p class="text-[9px] uppercase tracking-[0.4em] mb-3" style="color:var(--c-accent)">Selected Work</p>
        <h2 class="leading-none" style="font-family:var(--f-display);font-size:clamp(3rem,8vw,9rem);color:var(--c-text)">WORK</h2>
      </div>
      <p class="hidden lg:block text-sm font-light pb-4 max-w-xs text-right" style="color:var(--c-text-muted)">
        Every wedding treated as a fashion editorial — precise, bold, timeless.
      </p>
    </div>
    <!-- Full-width red rule -->
    <div class="w-full h-px mt-8" style="background:var(--c-accent)" aria-hidden="true"></div>
  </div>

  <!-- Gallery: 2-column asymmetric grid -->
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
      {galleries.map((gallery, i) => {
        const colSpan = [7, 5, 5, 7, 6, 6][i % 6];
        const aspect = i % 2 === 0 ? 'aspect-[3/4]' : 'aspect-[4/5]';
        return (
          <button
            class={`gallery-card group relative overflow-hidden col-span-12 lg:col-span-${colSpan} ${aspect} fade-hidden`}
            style={`transition-delay:${i*0.07}s`}
            aria-label={`Open ${gallery.title} gallery`}
            data-gallery-id={gallery.id}
            type="button"
          >
            <img src={gallery.coverImage} alt={gallery.coverAlt}
              class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105 group-hover:grayscale"
              loading="lazy" decoding="async" />
            <!-- B&W + accent overlay on hover -->
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-400 flex flex-col justify-end p-6 lg:p-8"
              style="background:linear-gradient(to top,rgba(10,10,10,0.85),transparent)">
              <div class="w-6 h-px mb-4" style="background:var(--c-accent)" aria-hidden="true"></div>
              <p class="text-[9px] uppercase tracking-[0.3em] mb-2" style="color:var(--c-accent)">{gallery.subtitle}</p>
              <p class="text-2xl lg:text-3xl" style="font-family:var(--f-display);color:white">{gallery.title}</p>
            </div>
            <!-- Gallery number -->
            <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <span class="text-[9px] uppercase tracking-[0.3em]" style="color:rgba(255,255,255,0.5)">0{i+1}</span>
            </div>
          </button>
        );
      })}
    </div>
  </div>
</section>

<!-- Lightbox (shared structure) -->
<div id="lightbox" class="lightbox-overlay" role="dialog" aria-modal="true" aria-label="Gallery lightbox">
  <div class="w-full max-w-5xl py-8 lg:py-16">
    <button id="lightbox-close" class="fixed top-6 right-6 lg:top-8 lg:right-8 z-10 flex items-center gap-3 transition-colors"
      style="color:white" aria-label="Close gallery" type="button">
      <span class="text-xs uppercase tracking-widest">Close</span>
      <span class="text-2xl leading-none" aria-hidden="true">×</span>
    </button>
    <div class="px-6 mb-10">
      <p id="lightbox-subtitle" class="text-[9px] uppercase tracking-[0.3em] mb-2" style="color:var(--c-accent)"></p>
      <h3 id="lightbox-title" class="text-3xl lg:text-5xl" style="font-family:var(--f-display);color:white"></h3>
    </div>
    <div id="lightbox-images" class="flex flex-col gap-4 px-6"></div>
  </div>
</div>

<script>
  const galData = JSON.parse((document.getElementById('galleries-data') as HTMLScriptElement)?.text || '[]');
  const lightbox = document.getElementById('lightbox');
  const closeBtn = document.getElementById('lightbox-close');
  const titleEl = document.getElementById('lightbox-title');
  const subtitleEl = document.getElementById('lightbox-subtitle');
  const imagesEl = document.getElementById('lightbox-images');

  function openGallery(id: string) {
    const g = galData.find((x: { id: string }) => x.id === id);
    if (!g || !lightbox || !titleEl || !subtitleEl || !imagesEl) return;
    titleEl.textContent = g.title; subtitleEl.textContent = g.subtitle; imagesEl.innerHTML = '';
    g.images.forEach((img: { src: string; alt: string }) => {
      const el = document.createElement('img');
      el.src = img.src; el.alt = img.alt; el.className = 'w-full h-auto object-cover'; el.loading = 'lazy'; el.decoding = 'async';
      imagesEl.appendChild(el);
    });
    lightbox.classList.add('active'); document.body.style.overflow = 'hidden'; closeBtn?.focus();
  }
  function closeLightbox() { lightbox?.classList.remove('active'); document.body.style.overflow = ''; if (imagesEl) imagesEl.innerHTML = ''; }

  document.querySelectorAll('[data-gallery-id]').forEach(btn => {
    btn.addEventListener('click', () => { const id = (btn as HTMLElement).dataset.galleryId; if (id) openGallery(id); });
  });
  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

  // Tilt on mousemove
  document.querySelectorAll('.gallery-card').forEach(card => {
    card.addEventListener('mousemove', (e: Event) => {
      const me = e as MouseEvent; const rect = (card as HTMLElement).getBoundingClientRect();
      const rx = ((me.clientY - rect.top) / rect.height - 0.5) * -4;
      const ry = ((me.clientX - rect.left) / rect.width - 0.5) * 4;
      (card as HTMLElement).style.transform = `perspective(1000px) rotateX(${rx}deg) rotateY(${ry}deg) scale(1.01)`;
    });
    card.addEventListener('mouseleave', () => { (card as HTMLElement).style.transform = ''; });
  });
</script>
