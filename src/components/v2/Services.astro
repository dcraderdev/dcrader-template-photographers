---
import type { Package } from '../../data/v1/packages';
interface Props { packages: Package[]; }
const { packages } = Astro.props;
---

<!-- V2: Editorial pricing — massive rates, stark ruled rows, crimson accent -->
<section id="services" class="py-20 lg:py-32" style="background:var(--c-bg-alt)" aria-label="Services and pricing">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <div class="flex items-end justify-between mb-10 fade-hidden">
      <h2 class="leading-none" style="font-family:var(--f-display);font-size:clamp(4rem,9vw,9rem);color:var(--c-text-inv);font-weight:900;letter-spacing:-0.03em">RATES</h2>
      <p class="hidden lg:block text-sm font-light pb-4 text-right max-w-xs" style="color:rgba(248,248,248,0.4);font-family:var(--f-body)">
        Transparent pricing. No guesswork. No surprises.
      </p>
    </div>

    <!-- Red rule -->
    <div class="w-full h-0.5 mb-0 fade-hidden" style="background:var(--c-accent);transition-delay:0.05s" aria-hidden="true"></div>

    <!-- Ruled list rows -->
    <div role="list">
      {packages.map((pkg, i) => (
        <div
          class="fade-hidden group"
          style={`border-bottom:1px solid rgba(248,248,248,0.08);transition-delay:${i*0.08}s`}
          role="listitem"
        >
          <div class="grid grid-cols-12 gap-4 items-center py-10 lg:py-12 transition-colors duration-300 group-hover:bg-white/5">

            <!-- Index -->
            <div class="col-span-2 lg:col-span-1">
              <span class="text-[8px] uppercase tracking-[0.4em]" style="color:rgba(248,248,248,0.25);font-family:var(--f-body)">0{i+1}</span>
            </div>

            <!-- Name + hours -->
            <div class="col-span-10 lg:col-span-3">
              <p class="text-[8px] uppercase tracking-[0.4em] mb-1.5" style="color:var(--c-accent);font-family:var(--f-body)">{pkg.hours}</p>
              <h3 class="leading-none" style="font-family:var(--f-display);font-size:clamp(1.8rem,3.5vw,3rem);color:var(--c-text-inv);font-weight:700;letter-spacing:-0.02em">
                {pkg.name}
              </h3>
            </div>

            <!-- Features as minimal tags -->
            <div class="hidden lg:flex col-span-5 flex-wrap gap-2" aria-label={`Includes: ${pkg.highlights.join(', ')}`}>
              {pkg.highlights.map(item => (
                <span class="text-[8px] uppercase tracking-wider px-3 py-1" style="border:1px solid rgba(248,248,248,0.12);color:rgba(248,248,248,0.35);font-family:var(--f-body)">
                  {item}
                </span>
              ))}
            </div>

            <!-- Price + CTA -->
            <div class="col-span-12 lg:col-span-3 flex items-center justify-between lg:justify-end gap-6 mt-4 lg:mt-0">
              <p class="leading-none" style="font-family:var(--f-display);font-size:clamp(2rem,4vw,3rem);color:var(--c-text-inv);font-weight:900;letter-spacing:-0.03em">
                {pkg.startingAt}
              </p>
              {pkg.featured && (
                <span class="text-[8px] uppercase tracking-[0.3em] px-3 py-1" style="background:var(--c-accent);color:white;font-family:var(--f-body)">
                  Popular
                </span>
              )}
              <a href="#inquire"
                class="text-[8px] uppercase tracking-[0.3em] px-6 py-3 transition-all duration-300 hover:bg-white hover:text-black"
                style="border:1px solid rgba(248,248,248,0.3);color:rgba(248,248,248,0.7);font-family:var(--f-body)">
                Book
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="mt-10 text-[9px] font-light fade-hidden" style="color:rgba(248,248,248,0.25);font-family:var(--f-body);transition-delay:0.35s">
      Rates in USD. Travel surcharges apply outside New York metro. International weddings quoted separately.
    </p>
  </div>
</section>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('fade-visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-hidden').forEach(el => obs.observe(el));
</script>
