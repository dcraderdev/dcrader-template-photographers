---
// V2 — Bold editorial
// Magazine "Press & Praise" spread: each testimonial is a column with venue masthead,
// pull-quote, byline. No avatar bubbles. Vendors credited in caps.
import type { Testimonial } from '../../data/v2/testimonials';

interface Props { testimonials: Testimonial[]; }
const { testimonials } = Astro.props;
---

<section id="testimonials" class="py-20 lg:py-32" style="background:var(--c-bg-alt)" aria-label="Press and praise">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <!-- Masthead-style header -->
    <div class="flex items-end justify-between mb-16 fade-hidden border-b pb-6" style="border-color:rgba(248,248,248,0.15)">
      <div>
        <p class="text-[9px] uppercase tracking-[0.55em] mb-3" style="color:var(--c-accent);font-family:var(--f-body)">Volume IV · Praise</p>
        <h2
          class="leading-none"
          style="font-family:var(--f-display);font-size:clamp(2.4rem,5.5vw,4.8rem);color:var(--c-text-inv);font-weight:900;letter-spacing:-0.03em"
        >
          On the record.
        </h2>
      </div>
      <p class="hidden lg:block text-[9px] uppercase tracking-[0.45em]" style="color:rgba(248,248,248,0.35);font-family:var(--f-body)">
        {String(testimonials.length).padStart(2,'0')} entries
      </p>
    </div>

    <!-- Four columns: each its own column rule, no card, no avatar -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-0">
      {testimonials.map((t, i) => (
        <article
          class={`fade-hidden px-6 lg:px-7 py-2 ${i > 0 ? 'lg:border-l' : ''}`}
          style={`border-color:rgba(248,248,248,0.12);transition-delay:${i*0.08}s`}
        >
          <p class="text-[8px] uppercase tracking-[0.45em] mb-3" style="color:var(--c-accent);font-family:var(--f-body)">
            ENTRY · {String(i+1).padStart(2,'0')}
          </p>
          <h3
            class="leading-none mb-5"
            style="font-family:var(--f-display);font-size:clamp(1.1rem,1.4vw,1.4rem);color:var(--c-text-inv);font-weight:900;letter-spacing:-0.02em"
          >
            {t.weddingInfo}
          </h3>
          <span class="block w-6 h-0.5 mb-5" style="background:var(--c-accent)" aria-hidden="true"></span>
          <blockquote
            class="leading-relaxed mb-6"
            style="font-family:var(--f-body);font-size:0.92rem;color:rgba(248,248,248,0.78);font-weight:300"
          >
            &ldquo;{t.quote}&rdquo;
          </blockquote>
          <footer class="pt-4" style="border-top:1px solid rgba(248,248,248,0.1)">
            <p class="text-[10px] uppercase tracking-[0.35em]" style="color:var(--c-text-inv);font-family:var(--f-body);font-weight:600">
              — {t.name}
            </p>
          </footer>
        </article>
      ))}
    </div>

    <!-- Footer slug line -->
    <p
      class="mt-16 text-[9px] uppercase tracking-[0.55em] fade-hidden"
      style="color:rgba(248,248,248,0.3);font-family:var(--f-body)"
    >
      Published with permission. Names unchanged. No retouching.
    </p>
  </div>
</section>
