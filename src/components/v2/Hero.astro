---
import ResponsiveImage from '../shared/ResponsiveImage.astro';
interface Props {
  name: string;
  subtagline: string;
  tagline: string;
  heroImage: string;
  heroImageAlt: string;
}
const { name, subtagline, tagline, heroImage, heroImageAlt } = Astro.props;
const [firstName, lastName] = name.split(' ');
---

<!-- V2: Full-bleed image, massive editorial type overlay — Bodoni magazine cover -->
<section id="hero" class="relative h-screen min-h-[700px] overflow-hidden" aria-label="Hero">

  <!-- Full-bleed photo -->
  <div class="absolute inset-0">
    <ResponsiveImage
      src={heroImage}
      alt={heroImageAlt}
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <!-- Heavy left-side gradient for text legibility -->
    <div class="absolute inset-0" style="background:linear-gradient(105deg, rgba(13,13,13,0.92) 0%, rgba(13,13,13,0.7) 45%, rgba(13,13,13,0.15) 100%)" aria-hidden="true"></div>
  </div>

  <!-- Content: left-aligned editorial -->
  <div class="relative h-full flex flex-col justify-between px-8 lg:px-16 pt-24 lg:pt-28 pb-10 lg:pb-14">

    <!-- Top: issue-style header bar -->
    <div class="flex items-center justify-between fade-hidden" style="transition-delay:0.05s">
      <div class="flex items-center gap-6">
        <span class="text-[9px] uppercase tracking-[0.5em] font-light" style="color:rgba(248,248,248,0.4);font-family:var(--f-body)">Portfolio</span>
        <span class="w-8 h-px" style="background:var(--c-accent)" aria-hidden="true"></span>
        <span class="text-[9px] uppercase tracking-[0.4em] font-light" style="color:var(--c-accent);font-family:var(--f-body)">New York</span>
      </div>
      <p class="hidden lg:block text-[9px] uppercase tracking-[0.4em] font-light" style="color:rgba(248,248,248,0.35);font-family:var(--f-body)">{subtagline}</p>
    </div>

    <!-- Middle: enormous editorial name -->
    <div class="flex-1 flex flex-col justify-center max-w-2xl">
      <!-- Red accent slash -->
      <div class="w-14 h-0.5 mb-8 fade-hidden" style="background:var(--c-accent);transition-delay:0.15s" aria-hidden="true"></div>

      <h1 class="leading-none fade-hidden" style="font-family:var(--f-display);color:var(--c-text-inv);font-weight:900;font-size:clamp(4rem,10vw,10rem);letter-spacing:-0.03em;transition-delay:0.25s">
        <span class="block">{firstName}</span>
        <span class="block italic" style="color:rgba(248,248,248,0.15);-webkit-text-stroke:1px rgba(248,248,248,0.4)">{lastName}</span>
      </h1>

      <p class="mt-8 text-base lg:text-lg font-light leading-relaxed max-w-sm fade-hidden" style="color:rgba(248,248,248,0.55);font-family:var(--f-body);transition-delay:0.4s">
        {tagline}
      </p>
    </div>

    <!-- Bottom: CTA bar -->
    <div class="flex items-center justify-between fade-hidden" style="transition-delay:0.55s">
      <div class="flex items-center gap-8">
        <a href="#galleries"
          class="text-[10px] uppercase tracking-[0.3em] px-8 py-3.5 transition-all duration-300 hover:opacity-90"
          style="background:var(--c-accent);color:white;font-family:var(--f-body)">
          View Work
        </a>
        <a href="#inquire"
          class="text-[10px] uppercase tracking-[0.3em] transition-colors"
          style="color:rgba(248,248,248,0.4);font-family:var(--f-body)">
          Inquire →
        </a>
      </div>

      <!-- Vertical scroll text -->
      <div class="hidden lg:flex flex-col items-center gap-3" aria-hidden="true">
        <span class="text-[8px] uppercase tracking-[0.4em] font-light" style="writing-mode:vertical-rl;color:rgba(248,248,248,0.25);font-family:var(--f-body)">Scroll to explore</span>
        <div class="w-px h-16 animate-pulse" style="background:rgba(248,248,248,0.15)"></div>
      </div>
    </div>
  </div>
</section>

