---
interface Props {
  name: string;
  subtagline: string;
  tagline: string;
  heroImage: string;
  heroImageAlt: string;
}
const { name, subtagline, tagline, heroImage, heroImageAlt } = Astro.props;
---

<!-- V2: Split layout — left=black+huge type, right=full-bleed photo -->
<section id="hero" class="relative flex min-h-screen overflow-hidden" aria-label="Hero">

  <!-- Left: editorial text panel -->
  <div class="relative z-10 flex flex-col justify-between w-full lg:w-[45%] px-10 lg:px-16 py-12 lg:py-16"
    style="background:var(--c-bg-alt)">

    <!-- Top: sub-label -->
    <div class="fade-hidden" style="transition-delay:0.1s">
      <p class="text-[10px] uppercase tracking-[0.35em] font-light" style="color:var(--c-accent)">{subtagline}</p>
    </div>

    <!-- Middle: massive name -->
    <div class="flex-1 flex flex-col justify-center">
      <!-- Red accent bar -->
      <div class="w-12 h-1 mb-8 fade-hidden" style="background:var(--c-accent);transition-delay:0.2s" aria-hidden="true"></div>
      <h1 class="leading-none mb-8 fade-hidden" style="font-family:var(--f-display);font-size:clamp(3.5rem,8vw,9rem);color:var(--c-text-inv);letter-spacing:-0.02em;transition-delay:0.3s">
        {name}
      </h1>
      <p class="text-base lg:text-lg font-light leading-relaxed max-w-xs fade-hidden" style="color:rgba(255,255,255,0.55);transition-delay:0.45s">
        {tagline}
      </p>
    </div>

    <!-- Bottom: CTA -->
    <div class="flex items-center gap-8 fade-hidden" style="transition-delay:0.6s">
      <a href="#galleries" class="text-xs uppercase tracking-[0.25em] px-8 py-4 transition-all duration-300"
        style="background:var(--c-accent);color:white">
        View Work
      </a>
      <a href="#inquire" class="text-xs uppercase tracking-[0.25em] transition-colors"
        style="color:rgba(255,255,255,0.45)">
        Inquire →
      </a>
    </div>
  </div>

  <!-- Right: full-height editorial photo -->
  <div class="hidden lg:block absolute inset-y-0 right-0 w-[55%]">
    <img
      src={heroImage}
      alt={heroImageAlt}
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <!-- Minimal gradient for text legibility at edge -->
    <div class="absolute inset-y-0 left-0 w-16" style="background:linear-gradient(to right,var(--c-bg-alt),transparent)" aria-hidden="true"></div>
  </div>

  <!-- Mobile: photo sits below text panel -->
  <div class="lg:hidden absolute inset-0 -z-10">
    <img src={heroImage} alt={heroImageAlt} class="w-full h-full object-cover opacity-30" loading="eager" fetchpriority="high" decoding="async" />
  </div>
</section>
