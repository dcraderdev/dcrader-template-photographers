---
// V2 footer — bold editorial.
// Newspaper colophon. Asymmetric layout: huge wordmark, columnar nav, single feature image.
import ResponsiveImage from '../shared/ResponsiveImage.astro';
interface Props {
  name: string;
  business: string;
  subtagline: string;
  instagram: string;
  instagramUrl: string;
  instagramPosts: Array<{ src: string; alt: string; }>;
}
const { name, business, subtagline, instagram, instagramUrl, instagramPosts } = Astro.props;
const lead = instagramPosts[0];
---

<footer style="background:var(--c-bg-alt);padding-top:5rem;padding-bottom:2rem" aria-label="Site footer">
  <div class="max-w-screen-xl mx-auto px-6 lg:px-16">

    <!-- Colophon header -->
    <div class="flex items-end justify-between mb-10 pb-4 fade-hidden" style="border-bottom:1px solid rgba(248,248,248,0.2)">
      <p class="text-[9px] uppercase tracking-[0.55em]" style="color:var(--c-accent);font-family:var(--f-body)">
        Colophon · End matter
      </p>
      <p class="hidden lg:block text-[9px] uppercase tracking-[0.4em]" style="color:rgba(248,248,248,0.4);font-family:var(--f-body)">
        Vol. IV · Issue {new Date().getFullYear()}
      </p>
    </div>

    <!-- Hero wordmark -->
    <a
      href={instagramUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="block fade-hidden transition-opacity hover:opacity-80"
      style="font-family:var(--f-display);font-size:clamp(3rem,9vw,8rem);color:var(--c-text-inv);font-weight:900;letter-spacing:-0.04em;line-height:0.95"
      aria-label={`Visit ${instagram} on Instagram (opens in new tab)`}
    >
      {instagram.replace('@','')}<span class="italic" style="color:var(--c-accent)">.</span>
    </a>

    <!-- Grid: feature image left, masthead right -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 mt-12 mb-16 fade-hidden" style="transition-delay:0.1s">

      <!-- Single big feature image -->
      <a
        href={instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="lg:col-span-7 group relative block overflow-hidden"
        style="aspect-ratio:16/9"
        aria-label={`${lead.alt} — view on Instagram (opens in new tab)`}
      >
        <ResponsiveImage
          src={lead.src}
          alt={lead.alt}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0" style="background:linear-gradient(to bottom right, transparent 60%, rgba(13,13,13,0.55) 100%)" aria-hidden="true"></div>
        <p
          class="absolute bottom-5 right-5 text-[10px] uppercase tracking-[0.4em]"
          style="color:white;font-family:var(--f-body);font-weight:600"
        >
          Latest · cover frame →
        </p>
      </a>

      <!-- Masthead columns -->
      <div class="lg:col-span-5 grid grid-cols-2 gap-6">
        <div>
          <p class="text-[8px] uppercase tracking-[0.5em] mb-3" style="color:var(--c-accent);font-family:var(--f-body)">Editor & Publisher</p>
          <p class="leading-tight" style="font-family:var(--f-display);font-size:1.4rem;color:var(--c-text-inv);font-weight:900;letter-spacing:-0.02em">{name}</p>
          <p class="text-[10px] uppercase tracking-[0.35em] mt-2" style="color:rgba(248,248,248,0.5);font-family:var(--f-body)">{subtagline}</p>
        </div>
        <nav aria-label="Footer navigation">
          <p class="text-[8px] uppercase tracking-[0.5em] mb-3" style="color:var(--c-accent);font-family:var(--f-body)">Sections</p>
          <ul class="space-y-2" style="list-style:none;padding:0;margin:0">
            {[['#galleries','Portfolio'],['#about','Profile'],['#services','Rates'],['#inquire','Inquire']].map(([href, label]) => (
              <li>
                <a href={href} class="text-[11px] uppercase tracking-[0.3em] transition-colors hover:opacity-100" style="color:rgba(248,248,248,0.65);font-family:var(--f-body);font-weight:600;opacity:0.85">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </div>

    <!-- Bottom rule -->
    <div class="pt-6 flex flex-col lg:flex-row items-center justify-between gap-4" style="border-top:1px solid rgba(248,248,248,0.15)">
      <p class="text-[9px] uppercase tracking-[0.45em]" style="color:rgba(248,248,248,0.4);font-family:var(--f-body)">
        © {new Date().getFullYear()} {business}. All rights reserved.
      </p>
      <p class="text-[9px] uppercase tracking-[0.4em]" style="color:rgba(248,248,248,0.3);font-family:var(--f-body)">
        Set in Playfair Display. Press inquiries welcome.
      </p>
    </div>

    <p class="text-center mt-8 text-[9px]" style="color:rgba(248,248,248,0.2)">Demo photography by Unsplash contributors.</p>
    <p class="text-center mt-3 text-[10px]" style="color:var(--c-text-muted)">
      Built by <a href="https://dcrader.dev" target="_blank" rel="noopener noreferrer" class="underline" style="color:var(--c-text-inv)">Donovan Crader</a> · <a href="https://dcrader.dev" target="_blank" rel="noopener noreferrer" style="color:var(--c-text-inv)">dcrader.dev</a>
    </p>
  </div>
</footer>
