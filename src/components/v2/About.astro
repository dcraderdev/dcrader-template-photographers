---
interface Props {
  name: string; portraitImage: string; portraitAlt: string;
  aboutParagraph1: string; aboutParagraph2: string;
  philosophyQuote: string; philosophyAuthor: string;
}
const p = Astro.props;
---

<!-- V2: Magazine spread — left=big portrait, right=editorial text, no background fill -->
<section id="about" aria-label={`About ${p.name}`} style="background:var(--c-bg)">

  <!-- Pull-quote bar (dark) -->
  <div class="py-16 lg:py-24 fade-hidden" style="background:var(--c-bg-alt)">
    <div class="max-w-screen-xl mx-auto px-6 lg:px-16">
      <p class="text-[8px] uppercase tracking-[0.5em] mb-8" style="color:var(--c-accent);font-family:var(--f-body)">— Profile</p>
      <blockquote
        class="leading-tight italic fade-hidden"
        style="font-family:var(--f-display);font-size:clamp(1.8rem,4vw,3.8rem);color:white;font-weight:400;max-width:900px;transition-delay:0.1s"
      >
        "{p.philosophyQuote}"
      </blockquote>
      <div class="flex items-center gap-4 mt-6 fade-hidden" style="transition-delay:0.2s">
        <div class="w-8 h-px" style="background:var(--c-accent)" aria-hidden="true"></div>
        <cite class="not-italic text-[8px] uppercase tracking-[0.5em]" style="color:rgba(248,248,248,0.35);font-family:var(--f-body)">{p.philosophyAuthor}</cite>
      </div>
    </div>
  </div>

  <!-- Main grid: portrait left, text right -->
  <div class="grid grid-cols-1 lg:grid-cols-2">

    <!-- Portrait: tall, bleeds -->
    <div class="relative overflow-hidden fade-hidden" style="min-height:520px">
      <img
        src={p.portraitImage}
        alt={p.portraitAlt}
        class="w-full h-full object-cover object-top"
        loading="lazy"
        decoding="async"
        style="min-height:500px"
      />
      <!-- Red rule bottom -->
      <div class="absolute bottom-0 left-0 right-0 h-1" style="background:var(--c-accent)" aria-hidden="true"></div>
    </div>

    <!-- Text: generous white padding -->
    <div class="px-8 lg:px-16 py-16 lg:py-24 flex flex-col justify-center fade-hidden" style="transition-delay:0.12s">

      <h2 class="leading-none mb-10 fade-hidden" style="font-family:var(--f-display);font-size:clamp(3rem,6vw,6rem);color:var(--c-text);font-weight:900;letter-spacing:-0.03em;transition-delay:0.18s">
        Daria<br /><span class="italic" style="font-weight:400;color:var(--c-text-muted)">Volkov</span>
      </h2>

      <div class="space-y-5 text-sm lg:text-base leading-relaxed font-light max-w-lg" style="color:var(--c-text-muted);font-family:var(--f-body)">
        <p set:html={p.aboutParagraph1}></p>
        <p set:html={p.aboutParagraph2}></p>
      </div>

      <!-- Press / features row -->
      <div class="mt-14 pt-8 fade-hidden" style="border-top:1px solid var(--c-border);transition-delay:0.28s">
        <div class="flex items-baseline gap-4 mb-7">
          <span class="block w-6 h-px" style="background:var(--c-accent)" aria-hidden="true"></span>
          <p class="text-[8px] uppercase tracking-[0.5em]" style="color:var(--c-text-muted);font-family:var(--f-body)">As featured in</p>
        </div>
        <ul
          class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-3 gap-x-8 gap-y-5"
          aria-label="Press features"
          style="list-style:none;padding:0"
        >
          {[
            { name: 'Vogue', sub: 'Russia · 2023' },
            { name: 'Harper&rsquo;s Bazaar', sub: 'Brides · 2024' },
            { name: 'Junebug Weddings', sub: 'Best of the Best' },
            { name: 'Brides Magazine', sub: 'Editorial · 2024' },
            { name: 'Vanity Fair', sub: 'Society Pages' },
            { name: 'Martha Stewart', sub: 'Weddings · 2025' },
          ].map(p => (
            <li>
              <p
                class="leading-none mb-1"
                style="font-family:var(--f-display);font-size:1.35rem;font-weight:900;color:var(--c-text);letter-spacing:-0.02em"
              >{p.name}</p>
              <p
                class="text-[7px] uppercase tracking-[0.4em]"
                style="color:var(--c-text-muted);font-family:var(--f-body)"
              >{p.sub}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

